<!doctype html>
<html lang="{{ request.locale.iso_code | default: 'es-MX' }}">
  {% liquid
    assign social_image = 'alicyn-product.png' | asset_url
    if settings.social_share_image != blank
      assign social_image = settings.social_share_image | image_url: width: 1200
    endif
  %}
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if page_title %}{{ page_title | escape }}{% else %}Alicyn 100 ml | Cuidado post-piercing{% endif %}</title>
    <meta name="description" content="{{ page_description | default: 'Alicyn 100 ml para cuidado post-piercing en México: limpieza responsable y sensación calmante en momentos clave de sudor, roce, piercing bump o sensibilidad común.' | escape }}">
    <link rel="canonical" href="{{ canonical_url | default: 'https://alicynmx.com/products/alicyn-solucion-antiseptica' }}">
    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64, height: 64 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {% endif %}

    <meta property="og:type" content="product">
    <meta property="og:title" content="Alicyn 100 ml | Cuidado post-piercing">
    <meta property="og:description" content="Cuida tus perforaciones en momentos clave de sudor, roce, cambio de joyería o sensibilidad común. Uso externo sobre piel sana. 100 ml.">
    <meta property="og:url" content="{{ canonical_url | default: 'https://alicynmx.com/products/alicyn-solucion-antiseptica' }}">
    <meta property="og:image" content="{{ social_image }}">
    <meta property="product:price:amount" content="350.00">
    <meta property="product:price:currency" content="MXN">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Alicyn 100 ml | Cuidado post-piercing">
    <meta name="twitter:description" content="Limpieza de piercing responsable en México y sensación calmante para momentos clave del proceso.">
    <meta name="twitter:image" content="{{ social_image }}">

    {{ 'alicyn.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body>
    {{ content_for_layout }}
    <script src="{{ 'alicyn.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
