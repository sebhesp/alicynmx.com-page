<!doctype html>
<html lang="{{ request.locale.iso_code | default: 'es-MX' }}">
  {% liquid
    assign social_image = 'alicyn-social-share.png' | asset_url
    if settings.social_share_image != blank
      assign social_image = settings.social_share_image | image_url: width: 1200
    endif
    assign favicon_image = 'alicyn-favicon.png' | asset_url
    if settings.favicon != blank
      assign favicon_image = settings.favicon | image_url: width: 64, height: 64
    endif
    assign apple_icon = 'alicyn-favicon.png' | asset_url
    if settings.favicon != blank
      assign apple_icon = settings.favicon | image_url: width: 180, height: 180
    endif
  %}
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if page_title %}{{ page_title | escape }}{% else %}Alicyn{% endif %}</title>
    <meta name="description" content="{{ page_description | default: 'Solución antiséptica de uso tópico externo para cuidado post-piercing, limpieza responsable y molestias comunes del proceso.' | escape }}">
    <link rel="canonical" href="{{ canonical_url | default: 'https://alicynmx.com/products/alicyn-solucion-antiseptica' }}">
    <link rel="icon" type="image/png" href="{{ favicon_image }}">
    <link rel="apple-touch-icon" href="{{ apple_icon }}">

    <meta property="og:type" content="product">
    <meta property="og:title" content="Alicyn">
    <meta property="og:description" content="Solución antiséptica de uso tópico externo para cuidado post-piercing, limpieza responsable y molestias comunes del proceso.">
    <meta property="og:url" content="{{ canonical_url | default: 'https://alicynmx.com/products/alicyn-solucion-antiseptica' }}">
    <meta property="og:image" content="{{ social_image }}">
    <meta property="product:price:amount" content="350.00">
    <meta property="product:price:currency" content="MXN">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Alicyn">
    <meta name="twitter:description" content="Solución antiséptica de uso tópico externo para cuidado post-piercing, limpieza responsable y molestias comunes del proceso.">
    <meta name="twitter:image" content="{{ social_image }}">

    {{ 'alicyn.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body>
    {{ content_for_layout }}
    <script src="{{ 'alicyn.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'alicyn-emotion.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
