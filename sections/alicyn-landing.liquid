{% liquid
  assign product_url = section.settings.product_url | default: '/products/alicyn-solucion-antiseptica'
  assign whatsapp_url = section.settings.whatsapp_url | default: 'https://wa.me/525542388056?text=Hola%2C%20quiero%20comprar%20Alicyn'
  assign instagram_url = section.settings.instagram_url | default: 'https://www.instagram.com/alicyn.mx/'
  assign product_size = section.settings.product_size | default: '100 ml'
  assign product_price = section.settings.product_price | default: '300.00'
  assign product_price_label = section.settings.product_price_label | default: '$300 MXN'
  assign primary_cta_label = section.settings.primary_cta_label | default: 'Comprar Alicyn 100 ml — $300 MXN'
  assign sticky_cta_label = section.settings.sticky_cta_label | default: 'Comprar Alicyn 100 ml — $300'
  assign product_canonical_url = product_url
  unless product_url contains 'http'
    assign product_canonical_url = 'https://alicynmx.com' | append: product_url
  endunless
  assign product_schema_image = 'alicyn-product.png' | asset_url
  if section.settings.product_image != blank
    assign product_schema_image = section.settings.product_image | image_url: width: 1200
  endif
%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ section.settings.schema_product_name | default: 'Alicyn Solución Antiséptica 100 ml' | json }},
    "brand": {
      "@type": "Brand",
      "name": "Alicyn"
    },
    "description": {{ section.settings.schema_description | default: 'Piercing aftercare de uso tópico externo para cuidar tus perforaciones con limpieza responsable y sensación calmante en momentos clave de mayor sensibilidad o exposición.' | json }},
    "image": {{ product_schema_image | json }},
    "sku": "ALICYN-100ML",
    "category": "Piercing aftercare",
    "material": "Sulfato de cobre, sulfato de zinc, alcanfor y agua destilada.",
    "url": {{ product_canonical_url | json }},
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "price": {{ product_price | json }},
      "availability": "https://schema.org/InStock",
      "url": {{ product_canonical_url | json }}
    },
    "additionalProperty": [
      {
        "@type": "PropertyValue",
        "name": "Contenido",
        "value": {{ product_size | json }}
      },
      {
        "@type": "PropertyValue",
        "name": "Uso",
        "value": "Externo, sobre piel sana. Evitar ojos y mucosas."
      }
    ]
  }
</script>

<div class="alicyn-page">
  <a class="skip-link" href="#contenido">Saltar al contenido</a>

  <aside class="announcement-bar" aria-label="Anuncio de envío">
    <span>{{ section.settings.announcement_text | escape }}</span>
  </aside>

  <header class="site-header" aria-label="Encabezado principal">
    <a class="brand" href="#producto" aria-label="Ir al inicio de Alicyn">
      <span class="brand-drop" aria-hidden="true"></span>
      <span>{{ section.settings.brand_text | escape }}</span>
    </a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-navigation"
      aria-label="Abrir navegación"
    >
      <span class="nav-toggle-line"></span>
      <span class="nav-toggle-line"></span>
    </button>
    <nav id="site-navigation" class="header-nav" aria-label="Navegación principal" data-open="false">
      <a href="#producto">Producto</a>
      <a href="#beneficios">Beneficios</a>
      <a href="#como-usarlo">Cómo usarlo</a>
      <a href="#experiencias">Experiencias</a>
      <a href="#estudios">Estudios</a>
      <a href="#faq">FAQ</a>
    </nav>
    <a class="header-cta" href="{{ product_url | escape }}">{{ section.settings.header_cta_label | escape }}</a>
  </header>

  <main id="contenido">
    <section id="producto" class="hero section-pad" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
        <h1 id="hero-title">{{ section.settings.hero_heading | escape }}</h1>
        <p class="hero-subcopy">{{ section.settings.hero_copy | escape | newline_to_br }}</p>
        <div class="hero-actions" aria-label="Acciones principales">
          <a class="button button-primary" href="{{ product_url | escape }}">
            {{ primary_cta_label | escape }}
            <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
              <path d="M5 12h12m-5-5 5 5-5 5"></path>
            </svg>
          </a>
          <a class="button button-secondary" href="#como-usarlo">{{ section.settings.secondary_cta_label | escape }}</a>
        </div>
        <dl class="hero-facts" aria-label="Resumen del producto">
          <div>
            <dt>{{ section.settings.hero_fact_1_label | escape }}</dt>
            <dd>{{ section.settings.hero_fact_1_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.hero_fact_2_label | escape }}</dt>
            <dd>{{ section.settings.hero_fact_2_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.hero_fact_3_label | escape }}</dt>
            <dd>{{ section.settings.hero_fact_3_value | escape }}</dd>
          </div>
        </dl>
      </div>

      <div class="hero-product" aria-label="Imagen de producto Alicyn">
        <!-- PRODUCT IMAGE BLOCK
          Preferred: choose the product image from the Shopify theme editor.
          Fallback asset path for GitHub/theme uploads: assets/alicyn-product.png
        -->
        <div class="product-stage" data-product-image-wrap>
          {% if section.settings.product_image != blank %}
            <img
              class="product-photo"
              src="{{ section.settings.product_image | image_url: width: 760 }}"
              srcset="
                {{ section.settings.product_image | image_url: width: 320 }} 320w,
                {{ section.settings.product_image | image_url: width: 520 }} 520w,
                {{ section.settings.product_image | image_url: width: 760 }} 760w
              "
              sizes="(min-width: 900px) 360px, 78vw"
              alt="{{ section.settings.product_image_alt | escape }}"
              width="640"
              height="840"
              loading="lazy"
              decoding="async"
              data-product-image
            >
          {% else %}
            <img
              class="product-photo"
              src="{{ 'alicyn-product.png' | asset_url }}"
              alt="{{ section.settings.product_image_alt | escape }}"
              width="640"
              height="840"
              loading="lazy"
              decoding="async"
              data-product-image
            >
          {% endif %}
          <div class="bottle-placeholder" aria-hidden="true">
            <div class="bottle-cap"></div>
            <div class="bottle-neck"></div>
            <div class="bottle-body">
              <span class="bottle-brand">ALICYN</span>
              <span class="bottle-line"></span>
              <span class="bottle-copy">Solución antiséptica</span>
              <span class="bottle-size">{{ product_size | escape }}</span>
            </div>
          </div>
          <div class="product-note">
            <span>{{ section.settings.product_note_label | escape }}</span>
            <strong>{{ section.settings.product_note_value | escape }}</strong>
          </div>
        </div>
        <!-- END PRODUCT IMAGE BLOCK -->
      </div>
    </section>

    {% if section.settings.show_packs %}
      {% render 'alicyn-product-packs',
        product_single_handle: section.settings.product_single_handle,
        product_pack_2_handle: section.settings.product_pack_2_handle,
        product_pack_3_handle: section.settings.product_pack_3_handle,
        product_pack_5_handle: section.settings.product_pack_5_handle,
        packs_eyebrow: section.settings.packs_eyebrow,
        packs_heading: section.settings.packs_heading,
        packs_copy: section.settings.packs_copy,
        whatsapp_url: whatsapp_url
      %}
    {% endif %}

    {% if section.settings.show_rewards %}
      {% render 'alicyn-rewards',
        product_url: product_url,
        rewards_eyebrow: section.settings.rewards_eyebrow,
        rewards_heading: section.settings.rewards_heading,
        rewards_copy: section.settings.rewards_copy
      %}
    {% endif %}

    {% for block in section.blocks %}
      {% case block.type %}
        {% when '@app' %}
          <div class="alicyn-app-block section-pad" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
      {% endcase %}
    {% endfor %}

    <section class="trust-strip" aria-label="Puntos de confianza">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'trust_badge' %}
            <div class="trust-item" {{ block.shopify_attributes }}>
              <span class="mini-icon" aria-hidden="true"></span>
              {{ block.settings.text | escape }}
            </div>
        {% endcase %}
      {% endfor %}
    </section>

    <section id="beneficios" class="section-pad benefits" aria-labelledby="benefits-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.benefits_eyebrow | escape }}</p>
        <h2 id="benefits-title">{{ section.settings.benefits_heading | escape }}</h2>
        <p>{{ section.settings.benefits_copy | escape | newline_to_br }}</p>
      </div>
      <div class="card-grid six-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'benefit' %}
              <article class="info-card" {{ block.shopify_attributes }}>
                <span class="card-icon {{ block.settings.icon }}" aria-hidden="true"></span>
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    </section>

    <section id="cuando-usar" class="section-pad usage-moments" aria-labelledby="moments-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.moments_eyebrow | escape }}</p>
        <h2 id="moments-title">{{ section.settings.moments_heading | escape }}</h2>
        <p>{{ section.settings.moments_copy | escape | newline_to_br }}</p>
      </div>
      <div class="moment-list">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'usage_moment' %}
              <article {{ block.shopify_attributes }}>
                <span>{{ block.settings.number | escape }}</span>
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    </section>

    <section id="senales-alerta" class="section-pad alert-section" aria-labelledby="alert-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.alert_eyebrow | escape }}</p>
        <h2 id="alert-title">{{ section.settings.alert_heading | escape }}</h2>
        <p>{{ section.settings.alert_copy | escape | newline_to_br }}</p>
      </div>
      <div class="signal-grid">
        <article class="signal-card">
          <h3>{{ section.settings.alert_common_heading | escape }}</h3>
          <p class="signal-list-text">{{ section.settings.alert_common_items | escape | newline_to_br }}</p>
        </article>
        <article class="signal-card signal-card-warning">
          <h3>{{ section.settings.alert_warning_heading | escape }}</h3>
          <p class="signal-list-text">{{ section.settings.alert_warning_items | escape | newline_to_br }}</p>
        </article>
      </div>
      <div class="care-note" role="note">
        {{ section.settings.alert_note | escape | newline_to_br }}
      </div>
    </section>

    <section id="como-usarlo" class="section-pad how-to" aria-labelledby="how-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.how_eyebrow | escape }}</p>
        <h2 id="how-title">{{ section.settings.how_heading | escape }}</h2>
        <p>{{ section.settings.how_copy | escape | newline_to_br }}</p>
      </div>
      <ol class="step-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'usage_step' %}
              <li {{ block.shopify_attributes }}>
                <span>{{ block.settings.number | escape }}</span>
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </li>
          {% endcase %}
        {% endfor %}
      </ol>
      <div class="care-note" role="note">
        {{ section.settings.how_note | escape | newline_to_br }}
      </div>
    </section>

    <section id="detalles" class="section-pad product-details" aria-labelledby="details-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.details_eyebrow | escape }}</p>
        <h2 id="details-title">{{ section.settings.details_heading | escape }}</h2>
      </div>
      <div class="details-layout">
        <div class="details-panel">
          <h3>{{ section.settings.details_product_title | escape }}</h3>
          <p>{{ section.settings.details_summary | escape | newline_to_br }}</p>
          <a class="button button-primary" href="{{ product_url | escape }}">{{ section.settings.details_cta_label | escape }}</a>
        </div>
        <dl class="details-list">
          <div>
            <dt>{{ section.settings.detail_1_label | escape }}</dt>
            <dd>{{ section.settings.detail_1_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_2_label | escape }}</dt>
            <dd>{{ section.settings.detail_2_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_3_label | escape }}</dt>
            <dd>{{ section.settings.detail_3_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_4_label | escape }}</dt>
            <dd>{{ section.settings.detail_4_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_5_label | escape }}</dt>
            <dd>{{ section.settings.detail_5_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_6_label | escape }}</dt>
            <dd>{{ section.settings.detail_6_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_7_label | escape }}</dt>
            <dd>{{ section.settings.detail_7_value | escape }}</dd>
          </div>
          <div>
            <dt>{{ section.settings.detail_8_label | escape }}</dt>
            <dd>{{ section.settings.detail_8_value | escape }}</dd>
          </div>
        </dl>
      </div>
    </section>

    <section id="experiencias" class="section-pad experiences" aria-labelledby="reviews-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.reviews_eyebrow | escape }}</p>
        <h2 id="reviews-title">{{ section.settings.reviews_heading | escape }}</h2>
        <p>{{ section.settings.reviews_copy | escape | newline_to_br }}</p>
      </div>
      <div class="review-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'testimonial' %}
              <article class="review-card" {{ block.shopify_attributes }}>
                <div class="review-top">
                  <strong>{{ block.settings.initials | escape }} · {{ block.settings.piercing | escape }}</strong>
                  <span>{{ block.settings.rating | escape }}</span>
                </div>
                <p>{{ block.settings.text | escape }}</p>
              </article>
          {% endcase %}
        {% endfor %}
      </div>
      <div class="section-disclaimer">{{ section.settings.reviews_disclaimer | escape }}</div>
    </section>

    <section class="section-pad story-section" aria-labelledby="story-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.story_eyebrow | escape }}</p>
        <h2 id="story-title">{{ section.settings.story_heading | escape }}</h2>
      </div>
      <div class="story-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'story_card' %}
              <article {{ block.shopify_attributes }}>
                <span>{{ block.settings.stage | escape }}</span>
                <h3>{{ block.settings.title | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    </section>

    <section id="estudios" class="section-pad studios" aria-labelledby="studios-title">
      <div class="studio-copy">
        <p class="eyebrow">{{ section.settings.studios_eyebrow | escape }}</p>
        <h2 id="studios-title">{{ section.settings.studios_heading | escape }}</h2>
        <p>{{ section.settings.studios_copy | escape | newline_to_br }}</p>
        <div class="studio-list-text">{{ section.settings.studios_features | escape | newline_to_br }}</div>
        <a class="button button-secondary" href="{{ section.settings.wholesale_request_url | escape }}">{{ section.settings.studios_cta_label | escape }}</a>
      </div>
      {% render 'alicyn-wholesale-pricing',
        wholesale_pack_5_handle: section.settings.wholesale_pack_5_handle,
        wholesale_pack_10_handle: section.settings.wholesale_pack_10_handle,
        wholesale_pack_20_handle: section.settings.wholesale_pack_20_handle,
        wholesale_pack_50_handle: section.settings.wholesale_pack_50_handle,
        wholesale_eyebrow: section.settings.wholesale_eyebrow,
        wholesale_heading: section.settings.wholesale_heading,
        wholesale_copy: section.settings.wholesale_copy,
        wholesale_request_eyebrow: section.settings.wholesale_request_eyebrow,
        wholesale_request_heading: section.settings.wholesale_request_heading,
        wholesale_request_copy: section.settings.wholesale_request_copy,
        wholesale_request_button: section.settings.wholesale_request_button,
        wholesale_request_url: section.settings.wholesale_request_url
      %}
    </section>

    <section id="faq" class="section-pad faq-section" aria-labelledby="faq-title">
      <div class="section-heading">
        <p class="eyebrow">{{ section.settings.faq_eyebrow | escape }}</p>
        <h2 id="faq-title">{{ section.settings.faq_heading | escape }}</h2>
      </div>
      <div class="faq-list" data-faq-list>
        {% assign faq_index = 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'faq_item' %}
              {% assign faq_index = faq_index | plus: 1 %}
              <article class="faq-item" {{ block.shopify_attributes }}>
                <h3>
                  <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-{{ faq_index }}">
                    {{ block.settings.question | escape }}
                    <span aria-hidden="true"></span>
                  </button>
                </h3>
                <div id="faq-{{ faq_index }}" class="faq-answer" hidden>
                  <p>{{ block.settings.answer | escape | newline_to_br }}</p>
                </div>
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    </section>

    <section class="final-cta section-pad" aria-labelledby="final-title">
      <p class="eyebrow">{{ section.settings.final_eyebrow | escape }}</p>
      <h2 id="final-title">{{ section.settings.final_heading | escape }}</h2>
      <p>{{ section.settings.final_copy | escape | newline_to_br }}</p>
      <div class="hero-actions">
        <a class="button button-primary" href="{{ product_url | escape }}">{{ section.settings.final_primary_label | escape }}</a>
        <a class="button button-secondary" href="{{ whatsapp_url | escape }}" target="_blank" rel="noopener noreferrer">
          {{ section.settings.final_secondary_label | escape }}
        </a>
      </div>
    </section>
  </main>

  <section class="chat-widget" aria-label="Chat de ayuda Alicyn">
    <button
      class="chat-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="chat-panel"
      aria-label="Abrir ayuda por WhatsApp"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
        <path d="M5 19.5 6.2 16A7.5 7.5 0 1 1 9 18.4l-4 1.1Z"></path>
        <path d="M8.8 10.2c.6 1.4 1.7 2.5 3 3.1.4.2.7.1.9-.2l.5-.6c.2-.3.5-.4.8-.3l1.5.6c.3.1.5.4.5.7 0 .7-.5 1.3-1.1 1.5-1 .3-2.9-.1-4.7-1.9-1.9-1.8-2.3-3.7-1.9-4.7.2-.6.8-1.1 1.5-1.1.3 0 .6.2.7.5l.6 1.5c.1.3 0 .6-.3.8l-.6.5c-.3.2-.4.5-.2.9Z"></path>
      </svg>
    </button>
    <div id="chat-panel" class="chat-panel" role="dialog" aria-modal="false" aria-labelledby="chat-title" hidden>
      <div class="chat-header">
        <div>
          <p id="chat-title">{{ section.settings.chat_title | escape }}</p>
          <span>{{ section.settings.chat_subtitle | escape }}</span>
        </div>
        <button class="chat-close" type="button" aria-label="Cerrar ayuda">{{ section.settings.chat_close_label | escape }}</button>
      </div>
      <div class="quick-questions" aria-label="Preguntas rápidas">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'chat_quick_reply' %}
              <button type="button" data-chat-message="{{ block.settings.message | escape }}" {{ block.shopify_attributes }}>
                {{ block.settings.label | escape }}
              </button>
          {% endcase %}
        {% endfor %}
      </div>
      <label class="chat-label" for="chat-message">{{ section.settings.chat_message_label | escape }}</label>
      <textarea id="chat-message" rows="3">{{ section.settings.chat_default_message | escape }}</textarea>
      <a
        id="chat-whatsapp-link"
        class="button button-primary chat-send"
        href="{{ whatsapp_url | escape }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ section.settings.chat_send_label | escape }}
      </a>
    </div>
  </section>

  <a class="sticky-mobile-cta" href="{{ product_url | escape }}">
    {{ sticky_cta_label | escape }}
  </a>

  <footer class="site-footer" aria-label="Pie de página">
    <div>
      <a class="brand footer-brand" href="#producto">
        <span class="brand-drop" aria-hidden="true"></span>
        <span>{{ section.settings.brand_text | escape }}</span>
      </a>
      <p>{{ section.settings.footer_copy | escape | newline_to_br }}</p>
    </div>
    <nav aria-label="Enlaces rápidos">
      <a href="#producto">Producto</a>
      <a href="#beneficios">Beneficios</a>
      <a href="#como-usarlo">Cómo usarlo</a>
      <a href="#experiencias">Experiencias</a>
      <a href="#estudios">Estudios</a>
      <a href="#faq">FAQ</a>
    </nav>
    <div class="footer-contact">
      <a href="{{ whatsapp_url | escape }}" target="_blank" rel="noopener noreferrer">WhatsApp</a>
      <a href="{{ instagram_url | escape }}" target="_blank" rel="noopener noreferrer">Instagram</a>
      <span>{{ section.settings.footer_badge_1 | escape }}</span>
      <span>{{ section.settings.footer_badge_2 | escape }}</span>
    </div>
  </footer>
</div>

{% schema %}
{
  "name": "Alicyn Landing",
  "max_blocks": 50,
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "product_url",
      "label": "Product URL",
      "default": "/products/alicyn-solucion-antiseptica"
    },
    {
      "type": "text",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "default": "https://wa.me/525542388056?text=Hola%2C%20quiero%20comprar%20Alicyn"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/alicyn.mx/"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "alicyn"
    },
    {
