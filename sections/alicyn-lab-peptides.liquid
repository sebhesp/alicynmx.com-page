                  <a class="alicyn-lab-text-link" data-lab-protocol-whatsapp data-name="{{ block.settings.protocol_name | escape }}" href="https://wa.me/{{ section.settings.whatsapp_number | default: '525542388056' }}?text=Hola%2C%20vengo%20de%20Alicyn%20Lab.%20Quiero%20orientaci%C3%B3n%20sobre%20un%20paquete%20t%C3%A9cnico." target="_blank" rel="noopener">Preguntar por WhatsApp</a>
