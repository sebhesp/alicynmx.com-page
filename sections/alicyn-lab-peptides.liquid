      function scrollToArea(key) {
        showLabScreen(key);
      }

      function whatsApp(message) {
        return 'https://wa.me/' + phone + '?text=' + encodeURIComponent(message);
      }

      function updateWhatsApp(routeKey) {
        var route = routes[routeKey];
        root.querySelectorAll('[data-lab-result-whatsapp]').forEach(function (link) {
          link.href = whatsApp(route.whatsapp);
        });
        root.querySelectorAll('[data-lab-whatsapp-route]').forEach(function (link) {
          var key = link.dataset.labWhatsappRoute;
          if (routes[key]) link.href = whatsApp(routes[key].whatsapp);
        });
        root.querySelectorAll('[data-lab-product-whatsapp]').forEach(function (link) {
          var card = link.closest('[data-lab-product-card]');
          if (card) link.href = whatsApp(card.dataset.productQuestion);
        });
        root.querySelectorAll('[data-lab-protocol-whatsapp]').forEach(function (link) {
          link.href = whatsApp('Hola, vengo de Alicyn Lab. Estoy interesado en ' + link.dataset.name + '. ¿Me pueden orientar?');
        });
      }

      function isProductInRoute(card, route) {
        var url = card.dataset.productUrl || '';
        return route.products.some(function (key) { return url.indexOf(productKeys[key]) !== -1; });
      }

      function applyFilter(filterKey) {
        activeFilter = filterKey;
        var route = routes[filterKey];
        root.querySelectorAll('[data-lab-filter]').forEach(function (button) {
          button.classList.toggle('is-active', button.dataset.labFilter === filterKey);
        });
        root.querySelectorAll('[data-lab-product-card]').forEach(function (card) {
          var related = route ? isProductInRoute(card, route) : true;
          card.classList.toggle('is-filtered', filterKey !== 'all' && !related);
        });
      }

      function setRoute(routeKey, shouldFilter) {
        var route = routes[routeKey] || routes.cell;
        activeRoute = routeKey in routes ? routeKey : 'cell';
        root.querySelector('[data-lab-result-route]').textContent = route.name;
        root.querySelector('[data-lab-result-copy]').textContent = route.copy;
        root.querySelector('[data-lab-result-primary]').textContent = route.primary;
        root.querySelector('[data-lab-result-complement]').textContent = route.complement;
        root.querySelector('[data-lab-result-level]').textContent = route.level;
        root.querySelector('[data-lab-result-product]').href = route.primaryUrl;
        root.querySelector('[data-lab-result-product]').textContent = 'Ver ' + route.primary;
        root.querySelectorAll('[data-lab-route]').forEach(function (button) {
          button.closest('.alicyn-lab-objective-card') && button.closest('.alicyn-lab-objective-card').classList.toggle('is-active', button.dataset.labRoute === activeRoute);
        });
        root.querySelectorAll('[data-lab-route-card]').forEach(function (card) {
          card.classList.toggle('is-active', card.dataset.labRouteCard === activeRoute);
        });
        root.querySelectorAll('[data-lab-product-card]').forEach(function (card) {
          card.classList.toggle('is-related', isProductInRoute(card, route));
        });
        root.querySelectorAll('[data-lab-compare-product]').forEach(function (row) {
          row.classList.toggle('is-related', route.products.indexOf(row.dataset.labCompareProduct) !== -1);
        });
        if (shouldFilter) applyFilter(activeRoute);
        updateWhatsApp(activeRoute);
      }

      function setAxis(axisKey) {
        var axis = axes[axisKey] || axes.energy;
        root.querySelector('[data-lab-map-title]').textContent = axis.title;
        root.querySelector('[data-lab-map-copy]').textContent = axis.copy;
        root.querySelector('[data-lab-map-products]').innerHTML = axis.products.map(function (name) {
          return '<span class="alicyn-lab-chip">' + name + '</span>';
        }).join('');
        root.querySelectorAll('[data-axis]').forEach(function (button) {
          button.classList.toggle('is-active', button.dataset.axis === axisKey);
        });
        root.querySelector('[data-lab-map-products-action]').onclick = function () {
          setRoute(axis.route, true);
          showLabScreen('objetivos');
        };
      }

      function selectView(viewKey, shouldScroll) {
        activeMode = viewKey === 'peptides' ? 'peptides' : 'care';
        root.querySelectorAll('[data-lab-view-trigger]').forEach(function (button) {
          var selected = button.dataset.labViewTrigger === activeMode;
          button.setAttribute('aria-selected', String(selected));
        });
        root.querySelectorAll('[data-lab-view]').forEach(function (panel) {
          panel.hidden = panel.dataset.labView !== activeMode;
        });
        root.querySelectorAll('[data-menu-mode]').forEach(function (menu) {
          menu.hidden = menu.dataset.menuMode !== activeMode;
        });
        root.querySelectorAll('[data-mode-nav]').forEach(function (button) {
          button.hidden = button.dataset.modeNav !== activeMode;
        });
        root.querySelector('[data-app-brand]').textContent = activeMode === 'care' ? 'ALICYN CARE' : 'ALICYN LAB';
        root.querySelector('[data-app-tagline]').textContent = activeMode === 'care' ? 'Cuidado · Confianza · Claridad' : 'Ciencia · Bienestar · Evolución';
        if (activeMode === 'care') showCarePanel(activeCarePanel, shouldScroll);
        else showLabScreen(activeLabScreen, shouldScroll);
        syncBottomNav();
        try { window.localStorage.setItem('alicynOSMode', activeMode); } catch (error) {}
      }

      function syncBottomNav() {
        var mobile = window.matchMedia && window.matchMedia('(max-width: 749px)').matches;
        var appVisible = Boolean(appInView);
        var visible = Boolean(bottomNav && mobile && appVisible);
        if (bottomNav) bottomNav.classList.toggle('is-visible', visible);
        if (traditionalSticky) {
          traditionalSticky.hidden = visible;
          traditionalSticky.style.display = visible ? 'none' : '';
        }
        if (traditionalChat) traditionalChat.style.display = appVisible ? 'none' : '';
      }

      function showQuizStep(step) {
        quizStep = Math.max(0, Math.min(step, quizFields.length - 1));
        quizFields.forEach(function (field, index) { field.hidden = index !== quizStep; });
        root.querySelector('[data-lab-quiz-step-label]').textContent = 'Pregunta ' + (quizStep + 1) + ' de ' + quizFields.length;
        root.querySelector('[data-lab-progress]').style.width = ((quizStep + 1) / quizFields.length * 100) + '%';
        root.querySelector('[data-lab-quiz-back]').disabled = quizStep === 0;
        root.querySelector('[data-lab-quiz-next]').textContent = quizStep === quizFields.length - 1 ? 'Ver resultado' : 'Siguiente';
      }

      function readAnswer(name) {
        var selection = root.querySelector('input[name="' + name + '"]:checked');
        return selection ? selection.value : '';
      }

      function quizResult() {
        var selectedRoute = readAnswer('objective') || 'starter';
        var experience = readAnswer('experience');
        var note = root.querySelector('[data-lab-experience-note]');
        setRoute(selectedRoute, true);
        if (experience === 'beginner') {
          note.hidden = false;
          note.textContent = 'Puedes empezar comparando opciones sin comprometerte a una ruta avanzada.';
        } else if (experience === 'advanced') {
          note.hidden = false;
          note.textContent = 'Consulta también los paquetes técnicos del mismo eje para una comparación más amplia.';
        } else {
          note.hidden = true;
        }
        showLabScreen('objetivos');
      }

      root.querySelectorAll('[data-lab-view-trigger]').forEach(function (button) {
        button.addEventListener('click', function () { selectView(button.dataset.labViewTrigger); });
      });

      root.querySelectorAll('[data-care-open]').forEach(function (button) {
        button.addEventListener('click', function () {
          showCarePanel(button.dataset.careOpen);
          root.querySelector('[data-lab-quick-menu]').hidden = true;
          root.querySelector('[data-lab-menu-toggle]').setAttribute('aria-expanded', 'false');
        });
      });

      root.querySelector('[data-lab-menu-toggle]').addEventListener('click', function (event) {
        var menu = root.querySelector('[data-lab-quick-menu]');
        var open = event.currentTarget.getAttribute('aria-expanded') === 'true';
        event.currentTarget.setAttribute('aria-expanded', String(!open));
        menu.hidden = open;
      });

      root.querySelectorAll('[data-lab-scroll-link]').forEach(function (link) {
        link.addEventListener('click', function () {
          root.querySelector('[data-lab-quick-menu]').hidden = true;
          root.querySelector('[data-lab-menu-toggle]').setAttribute('aria-expanded', 'false');
        });
      });

      root.querySelectorAll('[data-lab-go]').forEach(function (button) {
        button.addEventListener('click', function () {
          showLabScreen(button.dataset.labGo);
          root.querySelector('[data-lab-quick-menu]').hidden = true;
          root.querySelector('[data-lab-menu-toggle]').setAttribute('aria-expanded', 'false');
        });
      });

      root.querySelectorAll('[data-lab-route]').forEach(function (button) {
        button.addEventListener('click', function () {
          setRoute(button.dataset.labRoute, true);
          if (button.closest('[data-lab-route-card]')) showLabScreen('objetivos');
        });
      });

      root.querySelectorAll('[data-axis]').forEach(function (button) {
        button.addEventListener('click', function () { setAxis(button.dataset.axis); setRoute(button.dataset.route, false); });
      });

      root.querySelectorAll('[data-lab-filter]').forEach(function (button) {
        button.addEventListener('click', function () { applyFilter(button.dataset.labFilter); });
      });

      root.querySelector('[data-lab-reset-route]').addEventListener('click', function () {
        applyFilter('all');
        root.querySelectorAll('.alicyn-lab-objective-card').forEach(function (card) { card.classList.remove('is-active'); });
      });

      if (root.querySelector('[data-lab-quiz]')) {
        root.querySelector('[data-lab-quiz-next]').addEventListener('click', function () {
          var current = quizFields[quizStep];
          var chosen = current.querySelector('input:checked');
          if (!chosen) {
            current.querySelector('.alicyn-lab-choice').focus();
            return;
          }
          if (quizStep < quizFields.length - 1) showQuizStep(quizStep + 1);
          else quizResult();
        });
        root.querySelector('[data-lab-quiz-back]').addEventListener('click', function () { showQuizStep(quizStep - 1); });
        root.querySelector('[data-lab-clear-quiz]').addEventListener('click', function () {
          root.querySelector('[data-lab-quiz]').reset();
          showQuizStep(0);
        });
        showQuizStep(0);
      }

      root.querySelectorAll('[data-alicyn-lab-faq-button]').forEach(function (button) {
        button.addEventListener('click', function () {
          var answer = root.querySelector('#' + button.getAttribute('aria-controls'));
          var open = button.getAttribute('aria-expanded') === 'true';
          if (!answer) return;
          button.setAttribute('aria-expanded', String(!open));
          button.querySelector('span:last-child').textContent = open ? '+' : '-';
          answer.hidden = open;
        });
      });

      root.querySelectorAll('[data-lab-nav]').forEach(function (button) {
        button.addEventListener('click', function () { showLabScreen(button.dataset.labNav); });
      });

      if ('IntersectionObserver' in window) {
        var appObserver = new IntersectionObserver(function (entries) {
          appInView = entries.some(function (entry) { return entry.isIntersecting; });
          syncBottomNav();
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.02 });
        appObserver.observe(root);

      } else {
        appInView = true;
        syncBottomNav();
      }
      window.addEventListener('resize', syncBottomNav);

      var savedView = '{{ section.settings.default_mode | default: "care" }}';
      try { savedView = window.localStorage.getItem('alicynOSMode') || savedView; } catch (error) {}
      showCarePanel('inicio', false);
      showLabScreen('inicio', false);
      selectView(savedView === 'peptides' ? 'peptides' : 'care', false);
      setAxis('energy');
      setRoute('cell', false);
      updateWhatsApp('cell');
    })();
  </script>
</section>

