{% liquid
  assign care_single_handle = section.settings.care_single_handle | default: 'alicyn-solucion-antiseptica'
  assign care_pack_2_handle = section.settings.care_pack_2_handle | default: 'alicyn-pack-2'
  assign care_pack_3_handle = section.settings.care_pack_3_handle | default: 'alicyn-pack-3'
  assign care_pack_4_handle = section.settings.care_pack_4_handle | default: 'alicyn-pack-4'
  assign care_pack_5_handle = section.settings.care_pack_5_handle | default: 'alicyn-pack-5'
  assign care_single_product = all_products[care_single_handle]
  assign care_pack_2_product = all_products[care_pack_2_handle]
  assign care_pack_3_product = all_products[care_pack_3_handle]
  assign care_pack_4_product = all_products[care_pack_4_handle]
  assign care_pack_5_product = all_products[care_pack_5_handle]
  assign care_single_variant = care_single_product.selected_or_first_available_variant
  assign care_phone = section.settings.whatsapp_number | default: '525542388056'
  assign care_whatsapp = 'https://wa.me/' | append: care_phone | append: '?text=Hola%2C%20tengo%20una%20duda%20sobre%20Alicyn%20100%20ml.'
%}

<section
  id="AlicynLab-{{ section.id }}"
  class="alicyn-lab-root alicyn-lab-bg-{{ section.settings.background_mode }}"
  data-alicyn-lab-app
  data-whatsapp="{{ section.settings.whatsapp_number | default: '525542388056' | escape }}"
  style="--alicyn-lab-accent: {{ section.settings.accent_color }};"
>
  <style>
    #AlicynLab-{{ section.id }} {
      --alicyn-lab-bg: #070913;
      --alicyn-lab-surface: rgba(18, 20, 37, 0.78);
      --alicyn-lab-surface-solid: #111425;
      --alicyn-lab-surface-2: #171b31;
      --alicyn-lab-border: rgba(157, 132, 255, 0.2);
      --alicyn-lab-border-strong: rgba(157, 132, 255, 0.5);
      --alicyn-lab-text: #f5f4fb;
      --alicyn-lab-soft: #c9c7da;
      --alicyn-lab-muted: #9290a7;
      --alicyn-lab-violet: var(--alicyn-lab-accent, #956dff);
      --alicyn-lab-blue: #5e8dff;
      --alicyn-lab-cyan: #72d6e7;
      --alicyn-lab-success: #82dec8;
      --alicyn-lab-radius: 22px;
      --alicyn-lab-shadow: 0 26px 72px rgba(3, 3, 12, 0.46);
      --alicyn-lab-width: 1240px;
      position: relative;
      background:
        radial-gradient(circle at 88% 6%, rgba(121, 76, 255, 0.26), transparent 28rem),
        radial-gradient(circle at 8% 23%, rgba(42, 120, 255, 0.13), transparent 24rem),
        linear-gradient(180deg, #070913, #090b16 52%, #060811);
      color: var(--alicyn-lab-text);
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: clip;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-deep {
      --alicyn-lab-bg: #05060e;
      --alicyn-lab-surface-solid: #0c1020;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-soft {
      --alicyn-lab-bg: #0b0d18;
      --alicyn-lab-surface-solid: #15182a;
    }

    #AlicynLab-{{ section.id }} *,
    #AlicynLab-{{ section.id }} *::before,
    #AlicynLab-{{ section.id }} *::after {
      box-sizing: border-box;
    }

    #AlicynLab-{{ section.id }} img,
    #AlicynLab-{{ section.id }} svg {
      max-width: 100%;
    }

    #AlicynLab-{{ section.id }} [hidden] {
      display: none !important;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-shell {
      width: min(100%, var(--alicyn-lab-width));
      margin: 0 auto;
      padding: 0 16px 88px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-glass {
      border: 1px solid var(--alicyn-lab-border);
      border-radius: var(--alicyn-lab-radius);
      background: var(--alicyn-lab-surface);
      box-shadow: var(--alicyn-lab-shadow);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-app-header {
      position: sticky;
      top: 0;
      z-index: 20;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) 44px;
      gap: 10px;
      align-items: center;
      margin: 0 -16px;
      padding: 13px 16px 10px;
      background: rgba(7, 9, 19, 0.9);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-icon-button {
      display: inline-grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 14px;
      color: var(--alicyn-lab-text);
      background: rgba(255, 255, 255, 0.025);
      cursor: pointer;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-icon {
      width: 21px;
      height: 21px;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.75;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype {
      min-width: 0;
      color: var(--alicyn-lab-text);
      text-align: center;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype strong {
      display: block;
      font-size: 1rem;
      font-weight: 750;
      letter-spacing: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype span {
      display: block;
      margin-top: 3px;
      color: var(--alicyn-lab-muted);
      font-size: 0.62rem;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu {
      display: grid;
      gap: 7px;
      margin-top: 8px;
      padding: 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu a {
      border-radius: 12px;
      color: var(--alicyn-lab-soft);
      font-size: 0.94rem;
      padding: 11px 13px;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu button {
      width: 100%;
      border: 0;
      color: var(--alicyn-lab-soft);
      background: transparent;
      cursor: pointer;
      font-size: 0.94rem;
      padding: 11px 13px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu a:hover,
    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu button:hover {
      color: var(--alicyn-lab-text);
      background: rgba(149, 109, 255, 0.12);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      margin: 16px 0 22px;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
      padding: 4px;
    }

    #AlicynLab-{{ section.id }} .alicyn-os-label {
      margin: 13px auto -7px;
      color: var(--alicyn-lab-muted);
      font-size: 0.64rem;
      font-weight: 700;
      letter-spacing: 0;
      text-align: center;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch button {
      min-height: 46px;
      border: 0;
      border-radius: 999px;
      color: var(--alicyn-lab-muted);
      background: transparent;
      cursor: pointer;
      font-size: 0.92rem;
      font-weight: 700;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch button[aria-selected="true"] {
      color: var(--alicyn-lab-text);
      background: linear-gradient(120deg, rgba(118, 78, 245, 0.76), rgba(72, 105, 242, 0.68));
      box-shadow: 0 8px 26px rgba(108, 70, 244, 0.25);
    }

    #AlicynLab-{{ section.id }} button:focus-visible,
    #AlicynLab-{{ section.id }} a:focus-visible,
    #AlicynLab-{{ section.id }} input:focus-visible {
      outline: 2px solid var(--alicyn-lab-cyan);
      outline-offset: 3px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care {
      display: grid;
      gap: 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h1,
    #AlicynLab-{{ section.id }} .alicyn-lab-care h2,
    #AlicynLab-{{ section.id }} .alicyn-lab-hero h1,
    #AlicynLab-{{ section.id }} .alicyn-lab-hero h2,
    #AlicynLab-{{ section.id }} .alicyn-lab-heading {
      margin: 0;
      color: var(--alicyn-lab-text);
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      letter-spacing: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h1,
    #AlicynLab-{{ section.id }} .alicyn-lab-care h2 {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h3 {
      margin: 14px 0 12px;
      font-size: clamp(1.35rem, 6vw, 2rem);
      line-height: 1.18;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care p {
      max-width: 660px;
      margin: 0 0 24px;
      color: var(--alicyn-lab-soft);
      line-height: 1.68;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-panel {
      padding: 22px 18px;
      scroll-margin-top: 86px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-hero {
      display: grid;
      gap: 18px;
      padding: 24px 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-hero h1 {
      margin-bottom: 10px;
      font-size: clamp(2rem, 9vw, 3.5rem);
      line-height: 1.06;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-hero .alicyn-lab-section-copy {
      margin-bottom: 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-product-stage {
      position: relative;
      display: grid;
      min-height: 270px;
      place-items: center;
      border-radius: 20px;
      background: radial-gradient(circle at center, rgba(114, 214, 231, 0.15), transparent 62%);
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-product-image {
      display: block;
      width: auto;
      max-width: min(68%, 230px);
      max-height: 270px;
      object-fit: contain;
      filter: drop-shadow(0 20px 26px rgba(0, 0, 0, 0.42));
    }

    #AlicynLab-{{ section.id }} .alicyn-care-price-row {
      display: flex;
      gap: 10px;
      align-items: baseline;
      margin: 0 0 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-price-row strong {
      font-size: 1.45rem;
      color: var(--alicyn-lab-text);
    }

    #AlicynLab-{{ section.id }} .alicyn-care-price-row span {
      color: var(--alicyn-lab-muted);
      font-size: 0.84rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-dashboard {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-tile {
      display: grid;
      gap: 8px;
      min-height: 102px;
      border: 1px solid rgba(114, 214, 231, 0.16);
      border-radius: 17px;
      color: var(--alicyn-lab-text);
      background: rgba(114, 214, 231, 0.035);
      cursor: pointer;
      padding: 13px 12px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-tile .alicyn-lab-icon {
      color: var(--alicyn-lab-cyan);
    }

    #AlicynLab-{{ section.id }} .alicyn-care-tile strong {
      font-size: 0.9rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-back {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      border: 0;
      color: var(--alicyn-lab-cyan);
      background: transparent;
      cursor: pointer;
      font-weight: 700;
      margin: 0 0 18px;
      padding: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-list {
      display: grid;
      gap: 10px;
      margin: 16px 0 0;
      padding: 0;
      list-style: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-list li {
      display: flex;
      gap: 10px;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 14px;
      color: var(--alicyn-lab-soft);
      padding: 12px;
      line-height: 1.45;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-list li::before {
      flex: 0 0 8px;
      width: 8px;
      height: 8px;
      margin-top: 7px;
      border-radius: 50%;
      background: var(--alicyn-lab-cyan);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-care-packs {
      display: grid;
      gap: 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-pack {
      display: grid;
      gap: 8px;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.022);
      padding: 14px;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-pack-head {
      display: flex;
      gap: 10px;
      justify-content: space-between;
      align-items: baseline;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-pack-head span {
      color: var(--alicyn-lab-cyan);
      font-weight: 700;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-pack form,
    #AlicynLab-{{ section.id }} .alicyn-care-purchase form {
      margin: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-care-disclaimer {
      border-left: 2px solid rgba(114, 214, 231, 0.65);
      color: var(--alicyn-lab-soft);
      font-size: 0.85rem;
      margin-top: 17px;
      padding: 2px 0 2px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin: 0 0 11px;
      color: #b7a2ff;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker::before {
      width: 20px;
      height: 1px;
      background: var(--alicyn-lab-violet);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section {
      position: relative;
      padding: 36px 0 0;
      scroll-margin-top: 80px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-heading {
      max-width: 740px;
      margin-bottom: 10px;
      font-size: clamp(1.5rem, 6.3vw, 2.5rem);
      line-height: 1.15;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section-copy {
      max-width: 720px;
      margin: 0 0 22px;
      color: var(--alicyn-lab-soft);
      font-size: 0.95rem;
      line-height: 1.65;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero {
      display: grid;
      gap: 20px;
      padding-top: 10px;
      scroll-margin-top: 92px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-copy {
      padding: 25px 20px 22px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-title {
      margin-bottom: 13px;
      font-size: clamp(2rem, 9vw, 3.8rem);
      line-height: 1.06;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-text {
      margin: 0 0 22px;
      color: var(--alicyn-lab-soft);
      font-size: 0.98rem;
      line-height: 1.68;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button {
      display: inline-flex;
      min-height: 50px;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid transparent;
      border-radius: 15px;
      color: #fff;
      background: linear-gradient(118deg, #7b52f8, #557bf7);
      box-shadow: 0 15px 30px rgba(89, 73, 235, 0.22);
      cursor: pointer;
      font-size: 0.92rem;
      font-weight: 700;
      padding: 13px 17px;
      text-align: center;
      text-decoration: none;
      transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button:hover {
      box-shadow: 0 18px 34px rgba(99, 77, 246, 0.4);
      transform: translateY(-1px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button-secondary {
      border-color: var(--alicyn-lab-border);
      color: var(--alicyn-lab-text);
      background: rgba(255, 255, 255, 0.025);
      box-shadow: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button-tertiary {
      border-color: transparent;
      color: #bcadff;
      background: transparent;
      box-shadow: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 22px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badge {
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 999px;
      color: var(--alicyn-lab-soft);
      background: rgba(148, 111, 255, 0.08);
      font-size: 0.72rem;
      padding: 8px 11px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-compliance {
      margin: 20px 0 0;
      border-radius: 13px;
      color: var(--alicyn-lab-muted);
      background: rgba(115, 94, 220, 0.12);
      font-size: 0.78rem;
      line-height: 1.5;
      padding: 11px 13px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-media {
      position: relative;
      display: grid;
      min-height: 276px;
      place-items: center;
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-media::before {
      position: absolute;
      width: 78%;
      height: 78%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(120, 79, 252, 0.38), transparent 65%);
      filter: blur(14px);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-image {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      height: 100%;
      min-height: 276px;
      object-fit: cover;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit {
      position: relative;
      width: 220px;
      height: 220px;
      border: 1px solid rgba(134, 108, 255, 0.3);
      border-radius: 50%;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::before,
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::after {
      position: absolute;
      inset: 26px;
      border: 1px solid rgba(95, 142, 255, 0.28);
      border-radius: 50%;
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::after {
      inset: 54px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-core {
      position: absolute;
      inset: 84px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #fff;
      background: linear-gradient(135deg, #8158fb, #4b8df5);
      box-shadow: 0 0 45px rgba(113, 81, 255, 0.55);
      font-size: 0.68rem;
      font-weight: 700;
      text-align: center;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node {
      position: absolute;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--alicyn-lab-cyan);
      box-shadow: 0 0 12px var(--alicyn-lab-cyan);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(2) { top: 26px; left: 70px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(3) { top: 74px; right: 20px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(4) { right: 48px; bottom: 28px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(5) { left: 27px; bottom: 58px; }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-grid {
      display: grid;
      gap: 10px;
      margin-top: 18px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card {
      min-width: 0;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.02);
      padding: 13px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card svg {
      margin-bottom: 9px;
      color: #b7a2ff;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card strong {
      display: block;
      margin-bottom: 5px;
      font-size: 0.84rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card p {
      margin: 0;
      color: var(--alicyn-lab-muted);
      font-size: 0.74rem;
      line-height: 1.45;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map {
      display: grid;
      gap: 16px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map-stage {
      position: relative;
      min-height: 480px;
      overflow: hidden;
      padding: 18px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-figure {
      position: absolute;
      inset: 40px 0 30px;
      display: grid;
      place-items: center;
      pointer-events: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-figure svg {
      height: 390px;
      color: rgba(128, 103, 243, 0.55);
      filter: drop-shadow(0 0 24px rgba(103, 78, 232, 0.35));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot {
      position: absolute;
      display: inline-flex;
      align-items: center;
