            <button class="alicyn-lab-button" type="button" data-lab-go="quiz">Encontrar mi péptido</button>
            <button class="alicyn-lab-button alicyn-lab-button-secondary" type="button" data-lab-go="objetivos">Explorar por objetivo</button>
