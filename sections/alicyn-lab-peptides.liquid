      min-height: 55px;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border: 0;
      color: var(--alicyn-lab-text);
      background: transparent;
      cursor: pointer;
      font-size: 0.88rem;
      font-weight: 700;
      padding: 16px 14px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-answer {
      padding: 0 14px 15px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-answer p {
