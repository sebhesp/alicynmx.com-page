<section
  id="AlicynLab-{{ section.id }}"
  class="alicyn-lab-root alicyn-lab-bg-{{ section.settings.background_mode }}"
  style="--alicyn-lab-accent: {{ section.settings.accent_color }};"
>
  <style>
    #AlicynLab-{{ section.id }} {
      --alicyn-lab-bg: #080d13;
      --alicyn-lab-surface: #0f1720;
      --alicyn-lab-surface-2: #14212a;
      --alicyn-lab-line: rgba(157, 208, 212, 0.16);
      --alicyn-lab-text: #f0f3f2;
      --alicyn-lab-soft: #c3cccd;
      --alicyn-lab-muted: #88999d;
      --alicyn-lab-aqua: var(--alicyn-lab-accent, #8fbfc3);
      --alicyn-lab-lilac: #b8b4e7;
      --alicyn-lab-radius: 8px;
      --alicyn-lab-width: 1220px;
      background: var(--alicyn-lab-bg);
      color: var(--alicyn-lab-text);
      font-family: Arial, Helvetica, sans-serif;
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-deep {
      --alicyn-lab-bg: #05080c;
      --alicyn-lab-surface: #0b1219;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-soft {
      --alicyn-lab-bg: #0d1216;
      --alicyn-lab-surface: #151d22;
    }

    #AlicynLab-{{ section.id }} *,
    #AlicynLab-{{ section.id }} *::before,
    #AlicynLab-{{ section.id }} *::after {
      box-sizing: border-box;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-container {
      width: min(calc(100% - 36px), var(--alicyn-lab-width));
      margin: 0 auto;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section {
      padding: 62px 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      margin: 0 0 15px;
      color: var(--alicyn-lab-aqua);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker::before {
      display: inline-block;
      width: 26px;
      height: 1px;
      background: var(--alicyn-lab-aqua);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-heading {
      max-width: 820px;
      margin: 0 0 15px;
      color: var(--alicyn-lab-text);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.9rem, 8vw, 3.25rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section-copy {
      max-width: 760px;
      margin: 0 0 34px;
      color: var(--alicyn-lab-soft);
      font-size: 1rem;
      line-height: 1.72;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-brand {
      display: inline-flex;
      gap: 10px;
      align-items: baseline;
      margin-bottom: 52px;
      color: var(--alicyn-lab-text);
      font-size: 1.08rem;
      font-weight: 700;
      text-decoration: none;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-brand span {
      border-left: 1px solid var(--alicyn-lab-line);
      color: var(--alicyn-lab-aqua);
      font-size: 0.78rem;
      padding-left: 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero {
      position: relative;
      padding: 26px 0 68px;
      background:
        radial-gradient(circle at 78% 24%, rgba(143, 191, 195, 0.18), transparent 37%),
        radial-gradient(circle at 70% 62%, rgba(184, 180, 231, 0.09), transparent 34%);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-grid {
      display: grid;
      gap: 42px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-title {
      max-width: 780px;
      margin: 0 0 20px;
      color: var(--alicyn-lab-text);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.35rem, 9vw, 4.65rem);
      font-weight: 400;
      line-height: 1.03;
      letter-spacing: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-copy {
      max-width: 660px;
      margin: 0 0 30px;
      color: var(--alicyn-lab-soft);
      font-size: clamp(1rem, 3vw, 1.12rem);
      line-height: 1.7;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 30px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button {
      display: inline-flex;
      min-height: 51px;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--alicyn-lab-aqua);
      border-radius: var(--alicyn-lab-radius);
      color: #071015;
      background: var(--alicyn-lab-aqua);
      font-size: 0.94rem;
      font-weight: 700;
      padding: 14px 22px;
      text-align: center;
      text-decoration: none;
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button:hover {
      box-shadow: 0 14px 32px rgba(143, 191, 195, 0.2);
      transform: translateY(-1px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button-secondary {
      border-color: var(--alicyn-lab-line);
      color: var(--alicyn-lab-text);
      background: transparent;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button:focus-visible,
    #AlicynLab-{{ section.id }} .alicyn-lab-faq-button:focus-visible {
      outline: 2px solid var(--alicyn-lab-aqua);
      outline-offset: 3px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 27px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badge {
      border: 1px solid var(--alicyn-lab-line);
      border-radius: 999px;
      color: var(--alicyn-lab-soft);
      background: rgba(143, 191, 195, 0.05);
      font-size: 0.76rem;
      padding: 8px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-compliance {
      max-width: 680px;
      border-left: 2px solid var(--alicyn-lab-aqua);
      color: var(--alicyn-lab-muted);
      background: rgba(143, 191, 195, 0.05);
      font-size: 0.84rem;
      line-height: 1.55;
      padding: 13px 16px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-media {
      position: relative;
      display: grid;
      min-height: 370px;
      place-items: center;
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: linear-gradient(145deg, rgba(143, 191, 195, 0.11), rgba(15, 23, 32, 0.7) 54%, rgba(184, 180, 231, 0.08));
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-image {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 370px;
      object-fit: cover;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-visual {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 18px;
      width: min(80%, 310px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-vial {
      height: 86px;
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: rgba(255, 255, 255, 0.035);
      padding: 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-vial strong {
      display: block;
      margin-bottom: 8px;
      color: var(--alicyn-lab-aqua);
      font-size: 0.78rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-vial span {
      color: var(--alicyn-lab-muted);
      font-size: 0.78rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-education {
      border-top: 1px solid var(--alicyn-lab-line);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-education-panel {
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: var(--alicyn-lab-surface);
      padding: clamp(24px, 5vw, 45px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid {
      display: grid;
      gap: 14px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-journey-card {
      position: relative;
      border-top: 1px solid var(--alicyn-lab-line);
      padding: 22px 0 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-step-number {
      display: block;
      margin-bottom: 14px;
      color: var(--alicyn-lab-aqua);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 2rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-journey-card h3,
    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card h3 {
      margin: 0 0 10px;
      color: var(--alicyn-lab-text);
      font-size: 1.08rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-journey-card p,
    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card p {
      margin: 0;
      color: var(--alicyn-lab-soft);
      font-size: 0.92rem;
      line-height: 1.62;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card {
      position: relative;
      display: flex;
      flex-direction: column;
      min-width: 0;
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: linear-gradient(160deg, rgba(143, 191, 195, 0.055), rgba(15, 23, 32, 0.84) 46%, rgba(184, 180, 231, 0.035));
      overflow: hidden;
      padding: 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card-media {
      display: grid;
      min-height: 154px;
      place-items: center;
      margin: -18px -18px 18px;
      background: linear-gradient(135deg, rgba(143, 191, 195, 0.11), rgba(184, 180, 231, 0.045));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card-image {
      display: block;
      width: 100%;
      height: 172px;
      object-fit: contain;
      padding: 16px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card-placeholder {
      display: inline-flex;
      width: 78px;
      height: 92px;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      color: var(--alicyn-lab-aqua);
      font-size: 0.64rem;
      font-weight: 700;
      text-align: center;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card-badge {
      align-self: flex-start;
      border: 1px solid rgba(143, 191, 195, 0.23);
      border-radius: 999px;
      color: var(--alicyn-lab-aqua);
      font-size: 0.67rem;
      font-weight: 700;
      padding: 6px 9px;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card h3 {
      margin: 15px 0 8px;
      color: var(--alicyn-lab-text);
      font-size: 1.04rem;
      line-height: 1.38;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-price {
      display: block;
      margin: 0 0 8px;
      color: var(--alicyn-lab-aqua);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.65rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-compare {
      margin-left: 8px;
      color: var(--alicyn-lab-muted);
      font-size: 0.86rem;
      text-decoration: line-through;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-presentation,
    #AlicynLab-{{ section.id }} .alicyn-lab-focus {
      margin: 0 0 8px;
      color: var(--alicyn-lab-muted);
      font-size: 0.81rem;
      line-height: 1.5;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-focus strong {
      color: var(--alicyn-lab-soft);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-description {
      flex: 1;
      margin: 8px 0 18px;
      color: var(--alicyn-lab-soft);
      font-size: 0.9rem;
      line-height: 1.58;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-microcopy {
      margin: 16px 0 0;
      color: var(--alicyn-lab-muted);
      font-size: 0.72rem;
      line-height: 1.45;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-card .alicyn-lab-button {
      width: 100%;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-protocols {
      scroll-margin-top: 22px;
      background: rgba(143, 191, 195, 0.025);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-protocol-note {
      max-width: 900px;
      margin: 0 0 32px;
      border: 1px solid var(--alicyn-lab-line);
      color: var(--alicyn-lab-soft);
      background: rgba(143, 191, 195, 0.06);
      font-size: 0.92rem;
      line-height: 1.64;
      padding: 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card {
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: var(--alicyn-lab-surface);
      padding: 21px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card span {
      display: block;
      margin-top: 15px;
      color: var(--alicyn-lab-aqua);
      font-size: 0.81rem;
      line-height: 1.55;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-warning {
      border-top: 1px solid var(--alicyn-lab-line);
      border-bottom: 1px solid var(--alicyn-lab-line);
      background: var(--alicyn-lab-surface);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-warning-box {
      max-width: 940px;
      border-left: 3px solid var(--alicyn-lab-aqua);
      padding-left: 21px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-warning-box p {
      margin: 0;
      color: var(--alicyn-lab-soft);
      font-size: 0.96rem;
      line-height: 1.78;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-list {
      display: grid;
      gap: 9px;
      max-width: 900px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-item {
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: var(--alicyn-lab-surface);
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-button {
      display: flex;
      width: 100%;
      min-height: 58px;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      border: 0;
      color: var(--alicyn-lab-text);
      background: transparent;
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 700;
      padding: 17px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-button span:last-child {
      color: var(--alicyn-lab-aqua);
      font-size: 1.25rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-answer {
      border-top: 1px solid var(--alicyn-lab-line);
      color: var(--alicyn-lab-soft);
      font-size: 0.91rem;
      line-height: 1.68;
      padding: 0 17px 17px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-faq-answer p {
      margin: 15px 0 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-final {
      padding: 25px 0 70px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-final-card {
      display: grid;
      gap: 22px;
      align-items: center;
      border: 1px solid var(--alicyn-lab-line);
      border-radius: var(--alicyn-lab-radius);
      background: linear-gradient(100deg, rgba(143, 191, 195, 0.12), rgba(15, 23, 32, 0.95));
      padding: clamp(25px, 5vw, 42px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-final-card h2 {
      margin: 0 0 10px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.55rem, 5vw, 2.25rem);
      font-weight: 400;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-final-card p {
      margin: 0;
      color: var(--alicyn-lab-soft);
      line-height: 1.62;
    }

    @media (min-width: 750px) {
      #AlicynLab-{{ section.id }} .alicyn-lab-container {
        width: min(calc(100% - 64px), var(--alicyn-lab-width));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-actions {
        flex-direction: row;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-final-card {
        grid-template-columns: 1fr auto;
      }
    }

    @media (min-width: 990px) {
      #AlicynLab-{{ section.id }} .alicyn-lab-section {
        padding: 82px 0;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-hero {
        padding-bottom: 86px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-hero-grid {
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.68fr);
        align-items: center;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }
  </style>

  <div class="alicyn-lab-hero">
    <div class="alicyn-lab-container">
      <a class="alicyn-lab-brand" href="/" aria-label="Alicyn">ALICYN <span>LAB</span></a>
      <div class="alicyn-lab-hero-grid">
        <div>
          <p class="alicyn-lab-kicker">Colección beauty-tech de investigación</p>
          {% if section.settings.embed_as_home_section %}
            <h2 class="alicyn-lab-hero-title">{{ section.settings.heading | escape }}</h2>
          {% else %}
            <h1 class="alicyn-lab-hero-title">{{ section.settings.heading | escape }}</h1>
          {% endif %}
          <p class="alicyn-lab-hero-copy">{{ section.settings.subheading | escape }}</p>
          <div class="alicyn-lab-actions">
            <a class="alicyn-lab-button" href="{{ section.settings.primary_button_link | default: '/collections/peptidos' }}">{{ section.settings.primary_button_label | escape }}</a>
            <button class="alicyn-lab-button alicyn-lab-button-secondary" type="button" data-alicyn-lab-scroll>
              {{ section.settings.secondary_button_label | escape }}
            </button>
          </div>
          <div class="alicyn-lab-badges" aria-label="Ejes Alicyn Lab">
            <span class="alicyn-lab-badge">Investigación</span>
            <span class="alicyn-lab-badge">Wellness celular</span>
            <span class="alicyn-lab-badge">Skin science</span>
            <span class="alicyn-lab-badge">Aesthetic Labs</span>
          </div>
          <p class="alicyn-lab-compliance">Uso exclusivo para investigación y laboratorio. No apto para consumo humano o animal.</p>
        </div>
        <div class="alicyn-lab-hero-media">
          {% if section.settings.hero_image != blank %}
            {{ section.settings.hero_image | image_url: width: 1100 | image_tag:
              class: 'alicyn-lab-hero-image',
              loading: 'eager',
              widths: '420, 650, 900, 1100',
              sizes: '(min-width: 990px) 420px, 100vw',
              alt: 'Alicyn Lab colección de péptidos Aesthetic Labs para investigación'
            }}
          {% else %}
            <div class="alicyn-lab-hero-visual" aria-hidden="true">
              <div class="alicyn-lab-hero-vial"><strong>SKIN SCIENCE</strong><span>Señalización celular y análisis técnico</span></div>
              <div class="alicyn-lab-hero-vial"><strong>CELLULAR ENERGY</strong><span>Mitocondria y wellness avanzado</span></div>
              <div class="alicyn-lab-hero-vial"><strong>ALICYN LAB</strong><span>Aesthetic Labs · Investigación</span></div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="alicyn-lab-education alicyn-lab-section">
    <div class="alicyn-lab-container">
      <div class="alicyn-lab-education-panel">
        <p class="alicyn-lab-kicker">Fundamentos</p>
        <h2 class="alicyn-lab-heading">¿Qué son los péptidos en investigación beauty &amp; wellness?</h2>
        <p class="alicyn-lab-section-copy">Los péptidos son cadenas cortas de aminoácidos estudiadas en contextos científicos por su relación con procesos biológicos como señalización celular, metabolismo, respuesta tisular, colágeno, piel y energía celular. En Alicyn Lab se presentan desde un enfoque técnico, educativo y de investigación, sin presentar beneficios clínicos ni aplicaciones para personas o animales.</p>
      </div>
    </div>
  </div>

  <div class="alicyn-lab-section">
    <div class="alicyn-lab-container">
      <p class="alicyn-lab-kicker">Ruta educativa</p>
      <h2 class="alicyn-lab-heading">Aprende de poco en poco: de la piel al bienestar celular</h2>
      <p class="alicyn-lab-section-copy">Navega la colección por ejes de estudio y selecciona compuestos o paquetes comerciales según el contexto técnico de tu investigación.</p>
      <div class="alicyn-lab-journey-grid">
        {% assign alicyn_lab_step_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'education_step' %}
            {% assign alicyn_lab_step_index = alicyn_lab_step_index | plus: 1 %}
            <article class="alicyn-lab-journey-card" {{ block.shopify_attributes }}>
              <span class="alicyn-lab-step-number">0{{ alicyn_lab_step_index }}</span>
              <h3>{{ block.settings.step_title | escape }}</h3>
              <p>{{ block.settings.step_text | escape }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div id="catalogo-peptidos-investigacion" class="alicyn-lab-section">
    <div class="alicyn-lab-container">
      <p class="alicyn-lab-kicker">Colección individual</p>
      <h2 class="alicyn-lab-heading">Péptidos Aesthetic Labs para investigación beauty &amp; wellness</h2>
      <p class="alicyn-lab-section-copy">Selecciona productos individuales por eje de investigación. Cada ficha describe su presentación y enfoque comercial sin representar un beneficio clínico.</p>
      <div class="alicyn-lab-products-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product_card' %}
            <article class="alicyn-lab-card" {{ block.shopify_attributes }}>
              <div class="alicyn-lab-card-media">
                {% if block.settings.product_image != blank %}
                  {{ block.settings.product_image | image_url: width: 480 | image_tag:
                    class: 'alicyn-lab-card-image',
                    loading: 'lazy',
                    widths: '240, 360, 480',
                    sizes: '(min-width: 990px) 350px, (min-width: 750px) 50vw, 100vw',
                    alt: block.settings.product_name
                  }}
                {% else %}
                  <span class="alicyn-lab-card-placeholder">AESTHETIC<br>LABS</span>
                {% endif %}
              </div>
              <span class="alicyn-lab-card-badge">{{ block.settings.product_badge | escape }}</span>
              <h3>{{ block.settings.product_name | escape }}</h3>
              <p class="alicyn-lab-price">
                {{ block.settings.product_price | escape }}
                {% if block.settings.product_compare_at_price != blank %}
                  <span class="alicyn-lab-compare">{{ block.settings.product_compare_at_price | escape }}</span>
                {% endif %}
              </p>
              <p class="alicyn-lab-presentation">{{ block.settings.product_presentation | escape }}</p>
              <p class="alicyn-lab-focus"><strong>Eje:</strong> {{ block.settings.product_focus | escape }}</p>
              <p class="alicyn-lab-description">{{ block.settings.product_description | escape }}</p>
              {% if section.settings.show_card_links %}
                <a class="alicyn-lab-button alicyn-lab-button-secondary" href="{{ block.settings.product_link | default: '/collections/peptidos' }}">Ver producto</a>
              {% endif %}
              <p class="alicyn-lab-microcopy">Uso exclusivo para investigación y laboratorio.</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div id="protocolos-investigacion" class="alicyn-lab-protocols alicyn-lab-section">
    <div class="alicyn-lab-container">
      <p class="alicyn-lab-kicker">Paquetes técnicos</p>
      <h2 class="alicyn-lab-heading">Protocolos de investigación beauty &amp; wellness</h2>
      <p class="alicyn-lab-protocol-note">Estos protocolos son paquetes comerciales organizados por eje de investigación. No describen métodos de aplicación ni pautas para personas o animales. Sus nombres comerciales no representan resultados.</p>
      <div class="alicyn-lab-protocols-grid">
        {% for block in section.blocks %}
          {% if block.type == 'protocol_card' %}
            <article class="alicyn-lab-card" {{ block.shopify_attributes }}>
              {% if block.settings.protocol_image != blank %}
                <div class="alicyn-lab-card-media">
                  {{ block.settings.protocol_image | image_url: width: 480 | image_tag:
                    class: 'alicyn-lab-card-image',
                    loading: 'lazy',
                    widths: '240, 360, 480',
                    sizes: '(min-width: 990px) 350px, (min-width: 750px) 50vw, 100vw',
                    alt: block.settings.protocol_name
                  }}
                </div>
              {% endif %}
              <span class="alicyn-lab-card-badge">{{ block.settings.protocol_badge | escape }}</span>
              <h3>{{ block.settings.protocol_name | escape }}</h3>
              <p class="alicyn-lab-price">{{ block.settings.protocol_price | escape }}</p>
              <p class="alicyn-lab-presentation">{{ block.settings.protocol_components | escape }}</p>
              <p class="alicyn-lab-focus"><strong>Eje:</strong> {{ block.settings.protocol_focus | escape }}</p>
              <p class="alicyn-lab-description">{{ block.settings.protocol_description | escape }}</p>
              {% if section.settings.show_card_links %}
                <a class="alicyn-lab-button alicyn-lab-button-secondary" href="{{ block.settings.protocol_link | default: '/collections/peptidos' }}">Ver protocolo</a>
              {% endif %}
              <p class="alicyn-lab-microcopy">Paquete comercial para investigación y laboratorio.</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="alicyn-lab-section">
    <div class="alicyn-lab-container">
      <p class="alicyn-lab-kicker">Mapa de colección</p>
      <h2 class="alicyn-lab-heading">Elige por objetivo de investigación</h2>
      <p class="alicyn-lab-section-copy">Una forma simple de explorar los compuestos según el eje técnico de interés.</p>
      <div class="alicyn-lab-objectives-grid">
        <article class="alicyn-lab-objective-card">
          <h3>Skin Wellness</h3>
          <p>Estudio de piel y señalización celular.</p>
          <span>GHK-CU · NAD+ · BPC-157 · TB-500</span>
        </article>
        <article class="alicyn-lab-objective-card">
          <h3>Cellular Energy</h3>
          <p>Exploración técnica de energía celular.</p>
          <span>NAD+ · MOTS-C</span>
        </article>
        <article class="alicyn-lab-objective-card">
          <h3>Metabolic Research</h3>
          <p>Investigación metabólica experimental.</p>
          <span>AOD-9604 · HGH Fragment · RT-Triple Agonist · T3S@</span>
        </article>
        <article class="alicyn-lab-objective-card">
          <h3>Advanced Signaling</h3>
          <p>Señalización biológica experimental.</p>
          <span>CJC-1295 · Ipamorelin · IGF1-LR3</span>
        </article>
      </div>
    </div>
  </div>

  {% if section.settings.show_disclaimer %}
    <div class="alicyn-lab-warning alicyn-lab-section">
      <div class="alicyn-lab-container">
        <div class="alicyn-lab-warning-box">
          <p class="alicyn-lab-kicker">Responsabilidad</p>
          <h2 class="alicyn-lab-heading">Información importante antes de comprar</h2>
          <p>Los productos de esta colección están destinados exclusivamente para investigación, análisis técnico o uso de laboratorio. No son medicamentos, no son suplementos alimenticios, no son cosméticos y no están destinados al consumo humano o animal. La información presentada tiene fines educativos, descriptivos y comerciales. No constituye indicación médica, protocolo de uso, diagnóstico, tratamiento ni asesoría sanitaria.</p>
        </div>
      </div>
    </div>
  {% endif %}

  {% if section.settings.enable_faq %}
    <div class="alicyn-lab-section">
      <div class="alicyn-lab-container">
        <p class="alicyn-lab-kicker">Dudas comunes</p>
        <h2 class="alicyn-lab-heading">Preguntas frecuentes</h2>
        <div class="alicyn-lab-faq-list">
          {% assign alicyn_lab_faq_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'faq_item' %}
              {% assign alicyn_lab_faq_index = alicyn_lab_faq_index | plus: 1 %}
              <div class="alicyn-lab-faq-item" {{ block.shopify_attributes }}>
                <button
                  class="alicyn-lab-faq-button"
                  type="button"
                  aria-expanded="false"
                  aria-controls="AlicynLabFaq-{{ section.id }}-{{ alicyn_lab_faq_index }}"
                  data-alicyn-lab-faq-button
                >
                  <span>{{ block.settings.faq_question | escape }}</span>
                  <span aria-hidden="true">+</span>
                </button>
                <div id="AlicynLabFaq-{{ section.id }}-{{ alicyn_lab_faq_index }}" class="alicyn-lab-faq-answer" hidden>
                  <p>{{ block.settings.faq_answer | escape }}</p>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <div class="alicyn-lab-final">
    <div class="alicyn-lab-container">
      <div class="alicyn-lab-final-card">
        <div>
          <h2>Explora Alicyn Lab</h2>
          <p>Beauty-tech, wellness celular y ciencia aplicada a una colección de investigación clara y responsable.</p>
        </div>
        <a class="alicyn-lab-button" href="{{ section.settings.primary_button_link | default: '/collections/peptidos' }}">Ver colección de péptidos</a>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var root = document.getElementById('AlicynLab-{{ section.id }}');
      if (!root) return;

      var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var scrollButton = root.querySelector('[data-alicyn-lab-scroll]');
      var protocols = root.querySelector('#protocolos-investigacion');

      if (scrollButton && protocols) {
        scrollButton.addEventListener('click', function () {
          protocols.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
        });
      }

      root.querySelectorAll('[data-alicyn-lab-faq-button]').forEach(function (button) {
        button.addEventListener('click', function () {
          var answer = root.querySelector('#' + button.getAttribute('aria-controls'));
          var expanded = button.getAttribute('aria-expanded') === 'true';
          if (!answer) return;
          button.setAttribute('aria-expanded', String(!expanded));
          button.querySelector('span:last-child').textContent = expanded ? '+' : '-';
          answer.hidden = expanded;
        });
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Alicyn Lab Péptidos",
  "max_blocks": 50,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título principal",
      "default": "Alicyn Lab: Péptidos de Investigación para Belleza, Wellness y Longevidad Celular"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Explora compuestos de investigación Aesthetic Labs orientados al estudio de la piel, el bienestar celular, la señalización biológica y la ciencia detrás del cuidado avanzado."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Texto del botón principal",
      "default": "Ver colección de péptidos"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Enlace del botón principal",
      "default": "/collections/peptidos"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Texto del botón secundario",
      "default": "Conocer protocolos de investigación"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen del hero"
    },
    {
      "type": "select",
      "id": "background_mode",
      "label": "Fondo",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Oscuro" },
        { "value": "deep", "label": "Oscuro profundo" },
        { "value": "soft", "label": "Oscuro suave" }
      ]
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#8FBFC3"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Mostrar advertencia",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_faq",
      "label": "Mostrar preguntas frecuentes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_links",
      "label": "Mostrar enlaces de productos y protocolos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "embed_as_home_section",
      "label": "Usar como seccion dentro de home",
      "info": "Cambia el encabezado principal a H2 para no duplicar el H1 de la pagina de inicio.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Producto",
      "settings": [
        { "type": "text", "id": "product_name", "label": "Nombre", "default": "Aesthetic Labs GHK-CU 100 mg" },
        { "type": "text", "id": "product_price", "label": "Precio", "default": "$1,350 MXN" },
        { "type": "text", "id": "product_compare_at_price", "label": "Precio comparativo" },
        { "type": "text", "id": "product_presentation", "label": "Presentación", "default": "100 mg · Aesthetic Labs" },
        { "type": "text", "id": "product_focus", "label": "Eje beauty / wellness", "default": "Skin wellness y señalización celular" },
        { "type": "text", "id": "product_badge", "label": "Badge", "default": "Skin science" },
        { "type": "textarea", "id": "product_description", "label": "Descripción", "default": "Compuesto presentado para análisis técnico dentro del eje de skin wellness." },
        { "type": "url", "id": "product_link", "label": "Enlace del producto", "default": "/collections/peptidos" },
        { "type": "image_picker", "id": "product_image", "label": "Imagen del producto" }
      ]
    },
    {
      "type": "protocol_card",
      "name": "Protocolo",
      "settings": [
        { "type": "text", "id": "protocol_name", "label": "Nombre", "default": "Protocolo Piel y Longevidad Celular" },
        { "type": "text", "id": "protocol_price", "label": "Precio", "default": "$3,150 MXN" },
        { "type": "text", "id": "protocol_components", "label": "Componentes", "default": "GHK-CU + NAD+" },
        { "type": "text", "id": "protocol_focus", "label": "Eje", "default": "Skin wellness y longevidad celular" },
        { "type": "text", "id": "protocol_badge", "label": "Badge", "default": "Stack técnico" },
        { "type": "textarea", "id": "protocol_description", "label": "Descripción", "default": "Paquete comercial organizado para investigación dentro del mismo eje técnico." },
        { "type": "url", "id": "protocol_link", "label": "Enlace del protocolo", "default": "/collections/peptidos" },
        { "type": "image_picker", "id": "protocol_image", "label": "Imagen del protocolo" }
      ]
    },
    {
      "type": "education_step",
      "name": "Paso educativo",
      "settings": [
        { "type": "text", "id": "step_title", "label": "Título", "default": "Piel y señalización celular" },
        { "type": "textarea", "id": "step_text", "label": "Texto", "default": "Productos relacionados: GHK-CU, BPC-157 y TB-500." }
      ]
    },
    {
      "type": "faq_item",
      "name": "Pregunta frecuente",
      "settings": [
        { "type": "text", "id": "faq_question", "label": "Pregunta", "default": "¿Qué son los péptidos de investigación?" },
        { "type": "textarea", "id": "faq_answer", "label": "Respuesta", "default": "Son compuestos presentados para análisis técnico y educativo en entornos de investigación y laboratorio." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Alicyn Lab Péptidos"
    }
  ]
}
{% endschema %}
