                if lab_product == blank and block.settings.product_handle != blank
                  assign lab_product = all_products[block.settings.product_handle]
                endif
                if lab_product == blank and block.settings.product_link contains '/products/'
                  assign lab_inferred_handle = block.settings.product_link | split: '/products/' | last | split: '?' | first
                  assign lab_product = all_products[lab_inferred_handle]
                endif
                assign lab_product_url = block.settings.product_link | default: '/collections/peptidos'
                if lab_product != blank
                  assign lab_product_url = lab_product.url
                  assign lab_variant = lab_product.selected_or_first_available_variant
                endif
              %}
              <article
                class="alicyn-lab-card"
                data-lab-product-card
                data-product-url="{{ lab_product_url | escape }}"
                data-product-name="{{ block.settings.product_name | escape }}"
                data-product-question="Hola, vengo de Alicyn Lab. Estoy interesado en {{ block.settings.product_name | escape }}. ¿Me pueden orientar?"
                {{ block.shopify_attributes }}
              >
                <div class="alicyn-lab-card-media">
                  {% if block.settings.product_image != blank %}
                    {{ block.settings.product_image | image_url: width: 480 | image_tag: class: 'alicyn-lab-card-image', loading: 'lazy', widths: '240, 360, 480', sizes: '(min-width: 990px) 30vw, (min-width: 560px) 50vw, 100vw', alt: block.settings.product_name }}
                  {% elsif lab_product.featured_image != blank %}
                    {{ lab_product.featured_image | image_url: width: 480 | image_tag: class: 'alicyn-lab-card-image', loading: 'lazy', widths: '240, 360, 480', sizes: '(min-width: 990px) 30vw, (min-width: 560px) 50vw, 100vw', alt: block.settings.product_name }}
                  {% else %}
                    <span class="alicyn-lab-card-placeholder">AESTHETIC<br>LABS</span>
                  {% endif %}
                </div>
                <span class="alicyn-lab-card-badge">{{ block.settings.product_badge | escape }}</span>
                <h3>{{ block.settings.product_name | escape }}</h3>
                <p class="alicyn-lab-price">
                  {% if lab_product != blank %}{{ lab_product.price | money }}{% else %}{{ block.settings.product_price | escape }}{% endif %}
                  {% if block.settings.product_compare_at_price != blank %}<span class="alicyn-lab-compare">{{ block.settings.product_compare_at_price | escape }}</span>{% endif %}
                </p>
                <p class="alicyn-lab-presentation">{{ block.settings.product_presentation | escape }}</p>
                <p class="alicyn-lab-focus"><strong>Eje:</strong> {{ block.settings.product_focus | escape }}</p>
                <p class="alicyn-lab-description">{{ block.settings.product_description | escape }}</p>
                <div class="alicyn-lab-card-actions">
                  {% if section.settings.show_card_links %}
                    <a class="alicyn-lab-button alicyn-lab-button-secondary" href="{{ lab_product_url }}">Ver producto</a>
                  {% endif %}
                  {% if lab_product != blank and lab_variant.available %}
                    <form method="post" action="{{ routes.cart_add_url }}">
                      <input type="hidden" name="id" value="{{ lab_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button class="alicyn-lab-button" type="submit">Agregar al carrito</button>
                    </form>
                  {% else %}
                    <a class="alicyn-lab-button alicyn-lab-button-secondary" data-lab-product-whatsapp target="_blank" rel="noopener" href="https://wa.me/{{ section.settings.whatsapp_number | default: '525542388056' }}">Consultar disponibilidad</a>
                  {% endif %}
                  <a class="alicyn-lab-text-link" data-lab-product-whatsapp target="_blank" rel="noopener" href="https://wa.me/{{ section.settings.whatsapp_number | default: '525542388056' }}">Preguntar por WhatsApp</a>
                </div>
                <p class="alicyn-lab-microcopy">Uso exclusivo para investigación y laboratorio.</p>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div id="protocolos-investigacion" class="alicyn-lab-section">
        <p class="alicyn-lab-kicker">Paquetes técnicos</p>
        <h2 class="alicyn-lab-heading">Protocolos de investigación</h2>
        <p class="alicyn-lab-section-copy">Paquetes comerciales organizados por eje. No son instrucciones, cantidades ni recomendaciones para personas o animales.</p>
