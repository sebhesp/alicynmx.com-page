      color: var(--alicyn-lab-soft);
      line-height: 1.55;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav {
      position: fixed;
      right: 10px;
      bottom: calc(9px + env(safe-area-inset-bottom, 0px));
