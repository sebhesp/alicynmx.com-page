<section
  id="AlicynLab-{{ section.id }}"
  class="alicyn-lab-root alicyn-lab-bg-{{ section.settings.background_mode }}"
  data-alicyn-lab-app
  data-whatsapp="{{ section.settings.whatsapp_number | default: '525542388056' | escape }}"
  style="--alicyn-lab-accent: {{ section.settings.accent_color }};"
>
  <style>
    #AlicynLab-{{ section.id }} {
      --alicyn-lab-bg: #070913;
      --alicyn-lab-surface: rgba(18, 20, 37, 0.78);
      --alicyn-lab-surface-solid: #111425;
      --alicyn-lab-surface-2: #171b31;
      --alicyn-lab-border: rgba(157, 132, 255, 0.2);
      --alicyn-lab-border-strong: rgba(157, 132, 255, 0.5);
      --alicyn-lab-text: #f5f4fb;
      --alicyn-lab-soft: #c9c7da;
      --alicyn-lab-muted: #9290a7;
      --alicyn-lab-violet: var(--alicyn-lab-accent, #956dff);
      --alicyn-lab-blue: #5e8dff;
      --alicyn-lab-cyan: #72d6e7;
      --alicyn-lab-success: #82dec8;
      --alicyn-lab-radius: 22px;
      --alicyn-lab-shadow: 0 26px 72px rgba(3, 3, 12, 0.46);
      --alicyn-lab-width: 1240px;
      position: relative;
      background:
        radial-gradient(circle at 88% 6%, rgba(121, 76, 255, 0.26), transparent 28rem),
        radial-gradient(circle at 8% 23%, rgba(42, 120, 255, 0.13), transparent 24rem),
        linear-gradient(180deg, #070913, #090b16 52%, #060811);
      color: var(--alicyn-lab-text);
      font-family: Arial, Helvetica, sans-serif;
      overflow-x: clip;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-deep {
      --alicyn-lab-bg: #05060e;
      --alicyn-lab-surface-solid: #0c1020;
    }

    #AlicynLab-{{ section.id }}.alicyn-lab-bg-soft {
      --alicyn-lab-bg: #0b0d18;
      --alicyn-lab-surface-solid: #15182a;
    }

    #AlicynLab-{{ section.id }} *,
    #AlicynLab-{{ section.id }} *::before,
    #AlicynLab-{{ section.id }} *::after {
      box-sizing: border-box;
    }

    #AlicynLab-{{ section.id }} img,
    #AlicynLab-{{ section.id }} svg {
      max-width: 100%;
    }

    #AlicynLab-{{ section.id }} [hidden] {
      display: none !important;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-shell {
      width: min(100%, var(--alicyn-lab-width));
      margin: 0 auto;
      padding: 0 16px 88px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-glass {
      border: 1px solid var(--alicyn-lab-border);
      border-radius: var(--alicyn-lab-radius);
      background: var(--alicyn-lab-surface);
      box-shadow: var(--alicyn-lab-shadow);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-app-header {
      position: sticky;
      top: 0;
      z-index: 20;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) 44px;
      gap: 10px;
      align-items: center;
      margin: 0 -16px;
      padding: 13px 16px 10px;
      background: rgba(7, 9, 19, 0.9);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-icon-button {
      display: inline-grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 14px;
      color: var(--alicyn-lab-text);
      background: rgba(255, 255, 255, 0.025);
      cursor: pointer;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-icon {
      width: 21px;
      height: 21px;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.75;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype {
      min-width: 0;
      color: var(--alicyn-lab-text);
      text-align: center;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype strong {
      display: block;
      font-size: 1rem;
      font-weight: 750;
      letter-spacing: 0.12em;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-logotype span {
      display: block;
      margin-top: 3px;
      color: var(--alicyn-lab-muted);
      font-size: 0.62rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu {
      display: grid;
      gap: 7px;
      margin-top: 8px;
      padding: 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu a {
      border-radius: 12px;
      color: var(--alicyn-lab-soft);
      font-size: 0.94rem;
      padding: 11px 13px;
      text-decoration: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quick-menu a:hover {
      color: var(--alicyn-lab-text);
      background: rgba(149, 109, 255, 0.12);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      margin: 16px 0 22px;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
      padding: 4px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch button {
      min-height: 46px;
      border: 0;
      border-radius: 999px;
      color: var(--alicyn-lab-muted);
      background: transparent;
      cursor: pointer;
      font-size: 0.92rem;
      font-weight: 700;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-switch button[aria-selected="true"] {
      color: var(--alicyn-lab-text);
      background: linear-gradient(120deg, rgba(118, 78, 245, 0.76), rgba(72, 105, 242, 0.68));
      box-shadow: 0 8px 26px rgba(108, 70, 244, 0.25);
    }

    #AlicynLab-{{ section.id }} button:focus-visible,
    #AlicynLab-{{ section.id }} a:focus-visible,
    #AlicynLab-{{ section.id }} input:focus-visible {
      outline: 2px solid var(--alicyn-lab-cyan);
      outline-offset: 3px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care {
      padding: 34px 20px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h2,
    #AlicynLab-{{ section.id }} .alicyn-lab-hero h1,
    #AlicynLab-{{ section.id }} .alicyn-lab-hero h2,
    #AlicynLab-{{ section.id }} .alicyn-lab-heading {
      margin: 0;
      color: var(--alicyn-lab-text);
      font-family: Arial, Helvetica, sans-serif;
      font-weight: 700;
      letter-spacing: 0;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h2 {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care h3 {
      margin: 14px 0 12px;
      font-size: clamp(1.35rem, 6vw, 2rem);
      line-height: 1.18;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-care p {
      max-width: 660px;
      margin: 0 0 24px;
      color: var(--alicyn-lab-soft);
      line-height: 1.68;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin: 0 0 11px;
      color: #b7a2ff;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-kicker::before {
      width: 20px;
      height: 1px;
      background: var(--alicyn-lab-violet);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section {
      position: relative;
      padding: 36px 0 0;
      scroll-margin-top: 80px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-heading {
      max-width: 740px;
      margin-bottom: 10px;
      font-size: clamp(1.5rem, 6.3vw, 2.5rem);
      line-height: 1.15;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-section-copy {
      max-width: 720px;
      margin: 0 0 22px;
      color: var(--alicyn-lab-soft);
      font-size: 0.95rem;
      line-height: 1.65;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero {
      display: grid;
      gap: 20px;
      padding-top: 10px;
      scroll-margin-top: 92px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-copy {
      padding: 25px 20px 22px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-title {
      margin-bottom: 13px;
      font-size: clamp(2rem, 9vw, 3.8rem);
      line-height: 1.06;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-text {
      margin: 0 0 22px;
      color: var(--alicyn-lab-soft);
      font-size: 0.98rem;
      line-height: 1.68;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button {
      display: inline-flex;
      min-height: 50px;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid transparent;
      border-radius: 15px;
      color: #fff;
      background: linear-gradient(118deg, #7b52f8, #557bf7);
      box-shadow: 0 15px 30px rgba(89, 73, 235, 0.22);
      cursor: pointer;
      font-size: 0.92rem;
      font-weight: 700;
      padding: 13px 17px;
      text-align: center;
      text-decoration: none;
      transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button:hover {
      box-shadow: 0 18px 34px rgba(99, 77, 246, 0.4);
      transform: translateY(-1px);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button-secondary {
      border-color: var(--alicyn-lab-border);
      color: var(--alicyn-lab-text);
      background: rgba(255, 255, 255, 0.025);
      box-shadow: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-button-tertiary {
      border-color: transparent;
      color: #bcadff;
      background: transparent;
      box-shadow: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 22px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-badge {
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 999px;
      color: var(--alicyn-lab-soft);
      background: rgba(148, 111, 255, 0.08);
      font-size: 0.72rem;
      padding: 8px 11px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-compliance {
      margin: 20px 0 0;
      border-radius: 13px;
      color: var(--alicyn-lab-muted);
      background: rgba(115, 94, 220, 0.12);
      font-size: 0.78rem;
      line-height: 1.5;
      padding: 11px 13px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-media {
      position: relative;
      display: grid;
      min-height: 276px;
      place-items: center;
      overflow: hidden;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-media::before {
      position: absolute;
      width: 78%;
      height: 78%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(120, 79, 252, 0.38), transparent 65%);
      filter: blur(14px);
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hero-image {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      height: 100%;
      min-height: 276px;
      object-fit: cover;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit {
      position: relative;
      width: 220px;
      height: 220px;
      border: 1px solid rgba(134, 108, 255, 0.3);
      border-radius: 50%;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::before,
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::after {
      position: absolute;
      inset: 26px;
      border: 1px solid rgba(95, 142, 255, 0.28);
      border-radius: 50%;
      content: "";
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit::after {
      inset: 54px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-core {
      position: absolute;
      inset: 84px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #fff;
      background: linear-gradient(135deg, #8158fb, #4b8df5);
      box-shadow: 0 0 45px rgba(113, 81, 255, 0.55);
      font-size: 0.68rem;
      font-weight: 700;
      text-align: center;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node {
      position: absolute;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--alicyn-lab-cyan);
      box-shadow: 0 0 12px var(--alicyn-lab-cyan);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(2) { top: 26px; left: 70px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(3) { top: 74px; right: 20px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(4) { right: 48px; bottom: 28px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-orbit-node:nth-child(5) { left: 27px; bottom: 58px; }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-grid {
      display: grid;
      gap: 10px;
      margin-top: 18px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card {
      min-width: 0;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.02);
      padding: 13px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card svg {
      margin-bottom: 9px;
      color: #b7a2ff;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card strong {
      display: block;
      margin-bottom: 5px;
      font-size: 0.84rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-trust-card p {
      margin: 0;
      color: var(--alicyn-lab-muted);
      font-size: 0.74rem;
      line-height: 1.45;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map {
      display: grid;
      gap: 16px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map-stage {
      position: relative;
      min-height: 480px;
      overflow: hidden;
      padding: 18px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-figure {
      position: absolute;
      inset: 40px 0 30px;
      display: grid;
      place-items: center;
      pointer-events: none;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-figure svg {
      height: 390px;
      color: rgba(128, 103, 243, 0.55);
      filter: drop-shadow(0 0 24px rgba(103, 78, 232, 0.35));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot {
      position: absolute;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      max-width: 144px;
      border: 0;
      color: var(--alicyn-lab-soft);
      background: transparent;
      cursor: pointer;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 4px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot-dot {
      flex: 0 0 15px;
      width: 15px;
      height: 15px;
      border: 2px solid #e6deff;
      border-radius: 50%;
      background: var(--alicyn-lab-violet);
      box-shadow: 0 0 0 7px rgba(145, 104, 255, 0.14), 0 0 22px var(--alicyn-lab-violet);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot.is-active {
      color: #fff;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot.is-active .alicyn-lab-hotspot-dot {
      background: var(--alicyn-lab-cyan);
      box-shadow: 0 0 0 8px rgba(114, 214, 231, 0.15), 0 0 25px var(--alicyn-lab-cyan);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot[data-axis="energy"] { top: 58px; right: 15px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot[data-axis="skin"] { top: 116px; left: 12px; flex-direction: row-reverse; text-align: right; }
    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot[data-axis="metabolic"] { top: 225px; right: 8px; }
    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot[data-axis="tissue"] { bottom: 107px; left: 8px; flex-direction: row-reverse; text-align: right; }
    #AlicynLab-{{ section.id }} .alicyn-lab-hotspot[data-axis="performance"] { bottom: 39px; right: 5px; }

    #AlicynLab-{{ section.id }} .alicyn-lab-map-panel,
    #AlicynLab-{{ section.id }} .alicyn-lab-result-card {
      padding: 20px 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map-panel h3,
    #AlicynLab-{{ section.id }} .alicyn-lab-result-card h3 {
      margin: 0 0 7px;
      font-size: 1.22rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-map-panel p,
    #AlicynLab-{{ section.id }} .alicyn-lab-result-card p {
      margin: 0 0 14px;
      color: var(--alicyn-lab-soft);
      font-size: 0.9rem;
      line-height: 1.58;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin: 0 0 17px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-chip {
      border-radius: 999px;
      color: #ddd7ff;
      background: rgba(137, 102, 255, 0.16);
      font-size: 0.72rem;
      padding: 7px 10px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-inline-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-inline-actions .alicyn-lab-button {
      flex: 1 1 125px;
      min-height: 44px;
      font-size: 0.82rem;
      padding: 10px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-route-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid,
    #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid {
      display: grid;
      gap: 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card {
      position: relative;
      display: grid;
      grid-template-columns: 42px minmax(0, 1fr) 20px;
      gap: 12px;
      align-items: center;
      width: 100%;
      min-height: 104px;
      border: 1px solid var(--alicyn-lab-border);
      border-radius: 18px;
      color: inherit;
      background: rgba(255, 255, 255, 0.025);
      cursor: pointer;
      padding: 14px 13px;
      text-align: left;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card.is-active {
      border-color: var(--alicyn-lab-border-strong);
      background: linear-gradient(115deg, rgba(122, 78, 250, 0.21), rgba(75, 123, 247, 0.08));
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-icon {
      display: grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border-radius: 13px;
      color: #c9baff;
      background: rgba(143, 104, 255, 0.14);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card h3 {
      margin: 0 0 5px;
      font-size: 0.94rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-objective-card p {
      margin: 0;
      color: var(--alicyn-lab-muted);
      font-size: 0.76rem;
      line-height: 1.42;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-arrow {
      color: #a78dff;
      font-size: 1.25rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-card {
      margin-top: 15px;
      border-color: var(--alicyn-lab-border-strong);
      background:
        linear-gradient(135deg, rgba(129, 84, 252, 0.15), rgba(27, 32, 61, 0.76)),
        var(--alicyn-lab-surface);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-label {
      margin: 0 0 7px;
      color: #bcadff;
      font-size: 0.69rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-grid {
      display: grid;
      gap: 9px;
      margin: 16px 0 18px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-meta {
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.04);
      padding: 10px 12px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-meta span {
      display: block;
      color: var(--alicyn-lab-muted);
      font-size: 0.67rem;
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-result-meta strong {
      font-size: 0.85rem;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-quiz {
      padding: 19px 16px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-progress-head {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      color: var(--alicyn-lab-muted);
      font-size: 0.75rem;
    }

