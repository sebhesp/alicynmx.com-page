            {% assign alicyn_lab_faq_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'faq_item' %}
                {% assign alicyn_lab_faq_index = alicyn_lab_faq_index | plus: 1 %}
                <div class="alicyn-lab-faq-item" {{ block.shopify_attributes }}>
                  <button class="alicyn-lab-faq-button" type="button" aria-expanded="false" aria-controls="AlicynLabFaq-{{ section.id }}-{{ alicyn_lab_faq_index }}" data-alicyn-lab-faq-button><span>{{ block.settings.faq_question | escape }}</span><span aria-hidden="true">+</span></button>
                  <div id="AlicynLabFaq-{{ section.id }}-{{ alicyn_lab_faq_index }}" class="alicyn-lab-faq-answer" hidden><p>{{ block.settings.faq_answer | escape }}</p></div>
