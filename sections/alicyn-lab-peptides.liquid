      grid-template-columns: repeat(5, 1fr);
      gap: 2px;
      border: 1px solid rgba(148, 112, 255, 0.28);
      border-radius: 22px;
      background: rgba(11, 12, 25, 0.92);
      box-shadow: 0 20px 42px rgba(0, 0, 0, 0.42);
      padding: 7px 4px calc(7px + env(safe-area-inset-bottom, 0px));
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      opacity: 0;
      pointer-events: none;
      transform: translateY(calc(100% + 18px));
      transition: opacity 180ms ease, transform 180ms ease;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav button {
      display: grid;
      gap: 4px;
      min-height: 51px;
      place-items: center;
      border: 0;
      border-radius: 14px;
      color: var(--alicyn-lab-muted);
      background: transparent;
      cursor: pointer;
      font-size: 0.62rem;
      padding: 4px;
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav button.is-active {
      color: #dfd6ff;
      background: rgba(133, 93, 251, 0.17);
    }

    #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav .alicyn-lab-icon {
      width: 20px;
      height: 20px;
    }

    @media (min-width: 560px) {
      #AlicynLab-{{ section.id }} .alicyn-lab-result-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-route-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 750px) {
      #AlicynLab-{{ section.id }} .alicyn-lab-shell {
        padding-right: 28px;
        padding-bottom: 38px;
        padding-left: 28px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-app-header {
        position: relative;
        margin: 0;
        padding: 22px 0 12px;
        background: transparent;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-switch {
        width: 330px;
        margin: 12px auto 28px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-hero {
        grid-template-columns: minmax(400px, 1fr) minmax(300px, 0.7fr);
        gap: 18px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-hero-copy {
        padding: 38px 34px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-actions {
        flex-direction: row;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-trust-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-map {
        grid-template-columns: minmax(400px, 0.92fr) minmax(280px, 0.65fr);
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-bottom-nav {
        display: none;
      }
    }

    @media (min-width: 990px) {
      #AlicynLab-{{ section.id }} .alicyn-lab-section {
        padding-top: 55px;
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-objectives-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-route-grid {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-products-grid,
      #AlicynLab-{{ section.id }} .alicyn-lab-protocols-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #AlicynLab-{{ section.id }} .alicyn-lab-journey-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #AlicynLab-{{ section.id }} *,
      #AlicynLab-{{ section.id }} *::before,
      #AlicynLab-{{ section.id }} *::after {
        animation-duration: 0.001ms !important;
        scroll-behavior: auto !important;
        transition-duration: 0.001ms !important;
      }
    }
  </style>

  <div class="alicyn-lab-shell">
    <header class="alicyn-lab-app-header" aria-label="Navegación Alicyn Lab">
      <button class="alicyn-lab-icon-button" type="button" aria-label="Abrir navegación" aria-expanded="false" data-lab-menu-toggle>
        <svg class="alicyn-lab-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
      <a class="alicyn-lab-logotype" href="#AlicynLab-{{ section.id }}" aria-label="Alicyn Lab inicio">
        <strong>ALICYN LAB</strong>
        <span>Ciencia · Bienestar · Evolución</span>
      </a>
      <a class="alicyn-lab-icon-button" href="{{ routes.cart_url }}" aria-label="Ver carrito">
        <svg class="alicyn-lab-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h13l-1.5 8h-10L6 4H3"/><circle cx="9" cy="19" r="1.5"/><circle cx="17" cy="19" r="1.5"/></svg>
      </a>
    </header>

    <nav class="alicyn-lab-quick-menu alicyn-lab-glass" aria-label="Atajos Alicyn Lab" data-lab-quick-menu hidden>
      <a href="#alicyn-lab-objetivos-{{ section.id }}" data-lab-scroll-link>Explorar objetivos</a>
      <a href="#alicyn-lab-quiz-{{ section.id }}" data-lab-scroll-link>Encontrar mi ruta</a>
      <a href="#catalogo-peptidos-investigacion" data-lab-scroll-link>Ver productos</a>
      <a href="#alicyn-lab-comparador-{{ section.id }}" data-lab-scroll-link>Comparar opciones</a>
    </nav>

    <div class="alicyn-lab-switch" role="tablist" aria-label="Selecciona colección">
      <button type="button" role="tab" aria-selected="false" aria-controls="alicyn-lab-care-view-{{ section.id }}" data-lab-view-trigger="care">Antiséptico</button>
      <button type="button" role="tab" aria-selected="true" aria-controls="alicyn-lab-peptides-view-{{ section.id }}" data-lab-view-trigger="peptides">Péptidos</button>
    </div>

    <div id="alicyn-lab-care-view-{{ section.id }}" class="alicyn-lab-care alicyn-lab-glass" role="tabpanel" data-lab-view="care" hidden>
