  {% if section.settings.show_bottom_navigation %}
    <nav class="alicyn-lab-bottom-nav" aria-label="Navegación rápida de Alicyn Lab" data-lab-bottom-nav>
      <button class="is-active" type="button" data-lab-nav="inicio"><svg class="alicyn-lab-icon" viewBox="0 0 24 24"><path d="m4 11 8-7 8 7v9H4v-9ZM9 20v-6h6v6"/></svg><span>Inicio</span></button>
      <button type="button" data-lab-nav="objetivos"><svg class="alicyn-lab-icon" viewBox="0 0 24 24"><path d="M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Z"/><path d="m14.5 9.5-1.5 3-3 1.5 1.5-3 3-1.5Z"/></svg><span>Objetivos</span></button>
      <button type="button" data-lab-nav="quiz"><svg class="alicyn-lab-icon" viewBox="0 0 24 24"><path d="M9 4h6l1 2h3v15H5V6h3l1-2Z"/><path d="M9 11h6M9 15h4"/></svg><span>Quiz</span></button>
      <button type="button" data-lab-nav="productos"><svg class="alicyn-lab-icon" viewBox="0 0 24 24"><path d="M7 7h13l-1.5 8h-10L6 4H3"/><circle cx="9" cy="19" r="1.5"/><circle cx="17" cy="19" r="1.5"/></svg><span>Productos</span></button>
      <button type="button" data-lab-nav="comparar"><svg class="alicyn-lab-icon" viewBox="0 0 24 24"><path d="M7 4v16M17 4v16M4 8h6M14 13h6"/></svg><span>Más</span></button>
    </nav>
  {% endif %}
  </div>

  <script>
    (function () {
      var root = document.getElementById('AlicynLab-{{ section.id }}');
      if (!root || root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var phone = root.dataset.whatsapp || '525542388056';
      var destinations = {
        inicio: '#alicyn-lab-inicio-{{ section.id }}',
        objetivos: '#alicyn-lab-objetivos-{{ section.id }}',
        quiz: '#alicyn-lab-quiz-{{ section.id }}',
        productos: '#catalogo-peptidos-investigacion',
        comparar: '#alicyn-lab-comparador-{{ section.id }}'
      };
      var routes = {
        cell: {
          name: 'Cell Reset',
          primary: 'NAD+ 1000 mg',
          complement: 'MOTS-C 10 mg',
          level: 'Inicial / intermedio',
          copy: 'Ruta para explorar investigación sobre energía celular, metabolismo y bienestar avanzado.',
          products: ['nad', 'mots'],
          primaryUrl: '/products/aesthetic-labs-nad-1000-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Me recomendó la ruta Cell Reset con NAD+ y MOTS-C. ¿Me pueden orientar?'
        },
        lean: {
          name: 'Lean Research',
          primary: 'AOD-9604 10 mg',
          complement: 'MOTS-C 10 mg',
          level: 'Inicial / intermedio',
          copy: 'Ruta para explorar investigación sobre metabolismo y composición corporal desde un enfoque técnico.',
          products: ['aod', 'mots'],
          primaryUrl: '/products/aesthetic-labs-aod-9604-10-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Me recomendó la ruta Lean Research con AOD-9604 y MOTS-C. ¿Me pueden orientar?'
        },
        recovery: {
          name: 'Recovery Lab',
          primary: 'BPC-157',
          complement: 'TB-500',
          level: 'Intermedio',
          copy: 'Ruta enfocada en investigación sobre respuesta tisular y señalización en contextos técnicos.',
          products: ['bpc', 'tb'],
          primaryUrl: '/products/aesthetic-labs-bpc-157-10-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Me recomendó la ruta Recovery Lab con BPC-157 y TB-500. ¿Me pueden orientar?'
        },
        skin: {
          name: 'Skin Matrix',
          primary: 'GHK-Cu 100 mg',
          complement: 'NAD+ 1000 mg',
          level: 'Inicial / intermedio',
          copy: 'Ruta para explorar investigación en piel, colágeno, señalización celular y estética avanzada.',
          products: ['ghk', 'nad'],
          primaryUrl: '/products/aesthetic-labs-ghk-cu-100-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Me recomendó la ruta Skin Matrix con GHK-Cu y NAD+. ¿Me pueden orientar?'
        },
        performance: {
          name: 'Performance Axis',
          primary: 'MOTS-C 10 mg',
          complement: 'CJC-1295 sin DAC + Ipamorelin',
          level: 'Avanzado',
          copy: 'Ruta para comparar señalización experimental avanzada, energía celular y metabolismo.',
          products: ['mots', 'cjc', 'ipa'],
          primaryUrl: '/products/aesthetic-labs-mots-c-10-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Me recomendó la ruta Performance Axis con MOTS-C, CJC-1295 e Ipamorelin. ¿Me pueden orientar?'
        },
        starter: {
          name: 'Starter Lab',
          primary: 'NAD+ 1000 mg',
          complement: 'MOTS-C 10 mg',
          level: 'Inicial',
          copy: 'Ruta inicial para explorar energía celular y metabolismo con información educativa antes de elegir.',
          products: ['nad', 'mots'],
          primaryUrl: '/products/aesthetic-labs-nad-1000-mg',
          whatsapp: 'Hola, vengo de Alicyn Lab. Quiero comenzar con la ruta Starter Lab y comparar NAD+ con MOTS-C. ¿Me pueden orientar?'
        }
      };
      var axes = {
        energy: { title: 'Energía celular', copy: 'Exploración técnica asociada a energía celular, metabolismo y bienestar avanzado.', products: ['NAD+ 1000 mg', 'MOTS-C 10 mg'], route: 'cell' },
        skin: { title: 'Piel / rostro', copy: 'Skin science, colágeno y señalización celular como ejes de investigación.', products: ['GHK-Cu 100 mg', 'NAD+ 1000 mg'], route: 'skin' },
        metabolic: { title: 'Metabolismo', copy: 'Explora compuestos agrupados por investigación metabólica y composición corporal.', products: ['AOD-9604 10 mg', 'MOTS-C 10 mg'], route: 'lean' },
        tissue: { title: 'Tejidos', copy: 'Respuesta tisular y señalización en entornos de investigación experimental.', products: ['BPC-157', 'TB-500'], route: 'recovery' },
        performance: { title: 'Performance técnico', copy: 'Energía y señalización experimental avanzada organizadas para comparar.', products: ['MOTS-C 10 mg', 'CJC-1295 sin DAC', 'Ipamorelin'], route: 'performance' }
      };
      var productKeys = {
        nad: 'aesthetic-labs-nad-1000-mg',
        mots: 'aesthetic-labs-mots-c-10-mg',
        aod: 'aesthetic-labs-aod-9604-10-mg',
        bpc: 'aesthetic-labs-bpc-157-10-mg',
        tb: 'aesthetic-labs-tb-500-10-mg',
        ghk: 'aesthetic-labs-ghk-cu-100-mg',
        cjc: 'aesthetic-labs-cjc-1295-sin-dac-10-mg',
        ipa: 'aesthetic-labs-ipamorelin-10-mg'
      };
      var activeRoute = 'cell';
      var activeFilter = 'all';
      var quizStep = 0;
      var quizFields = root.querySelectorAll('[data-question]');
      var bottomNav = root.querySelector('[data-lab-bottom-nav]');
      var traditionalSticky = document.querySelector('.alicyn-page .sticky-mobile-cta');
      var traditionalChat = document.querySelector('.alicyn-page .chat-widget');
      var appInView = false;

      function scrollToArea(key) {
        var target = root.querySelector(destinations[key]);
        if (target) target.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
      }

      function whatsApp(message) {
        return 'https://wa.me/' + phone + '?text=' + encodeURIComponent(message);
      }

      function updateWhatsApp(routeKey) {
        var route = routes[routeKey];
        root.querySelectorAll('[data-lab-result-whatsapp]').forEach(function (link) {
          link.href = whatsApp(route.whatsapp);
        });
        root.querySelectorAll('[data-lab-whatsapp-route]').forEach(function (link) {
          var key = link.dataset.labWhatsappRoute;
          if (routes[key]) link.href = whatsApp(routes[key].whatsapp);
        });
        root.querySelectorAll('[data-lab-product-whatsapp]').forEach(function (link) {
          var card = link.closest('[data-lab-product-card]');
          if (card) link.href = whatsApp(card.dataset.productQuestion);
        });
        root.querySelectorAll('[data-lab-protocol-whatsapp]').forEach(function (link) {
          link.href = whatsApp('Hola, vengo de Alicyn Lab. Estoy interesado en ' + link.dataset.name + '. ¿Me pueden orientar?');
        });
      }

      function isProductInRoute(card, route) {
        var url = card.dataset.productUrl || '';
        return route.products.some(function (key) { return url.indexOf(productKeys[key]) !== -1; });
      }

      function applyFilter(filterKey) {
        activeFilter = filterKey;
        var route = routes[filterKey];
        root.querySelectorAll('[data-lab-filter]').forEach(function (button) {
          button.classList.toggle('is-active', button.dataset.labFilter === filterKey);
        });
        root.querySelectorAll('[data-lab-product-card]').forEach(function (card) {
          var related = route ? isProductInRoute(card, route) : true;
          card.classList.toggle('is-filtered', filterKey !== 'all' && !related);
        });
      }

      function setRoute(routeKey, shouldFilter) {
        var route = routes[routeKey] || routes.cell;
        activeRoute = routeKey in routes ? routeKey : 'cell';
        root.querySelector('[data-lab-result-route]').textContent = route.name;
        root.querySelector('[data-lab-result-copy]').textContent = route.copy;
        root.querySelector('[data-lab-result-primary]').textContent = route.primary;
        root.querySelector('[data-lab-result-complement]').textContent = route.complement;
        root.querySelector('[data-lab-result-level]').textContent = route.level;
        root.querySelector('[data-lab-result-product]').href = route.primaryUrl;
        root.querySelector('[data-lab-result-product]').textContent = 'Ver ' + route.primary;
        root.querySelectorAll('[data-lab-route]').forEach(function (button) {
          button.closest('.alicyn-lab-objective-card') && button.closest('.alicyn-lab-objective-card').classList.toggle('is-active', button.dataset.labRoute === activeRoute);
        });
        root.querySelectorAll('[data-lab-route-card]').forEach(function (card) {
          card.classList.toggle('is-active', card.dataset.labRouteCard === activeRoute);
        });
        root.querySelectorAll('[data-lab-product-card]').forEach(function (card) {
          card.classList.toggle('is-related', isProductInRoute(card, route));
        });
        root.querySelectorAll('[data-lab-compare-product]').forEach(function (row) {
          row.classList.toggle('is-related', route.products.indexOf(row.dataset.labCompareProduct) !== -1);
        });
        if (shouldFilter) applyFilter(activeRoute);
        updateWhatsApp(activeRoute);
      }

      function setAxis(axisKey) {
        var axis = axes[axisKey] || axes.energy;
        root.querySelector('[data-lab-map-title]').textContent = axis.title;
        root.querySelector('[data-lab-map-copy]').textContent = axis.copy;
        root.querySelector('[data-lab-map-products]').innerHTML = axis.products.map(function (name) {
          return '<span class="alicyn-lab-chip">' + name + '</span>';
        }).join('');
        root.querySelectorAll('[data-axis]').forEach(function (button) {
          button.classList.toggle('is-active', button.dataset.axis === axisKey);
        });
        root.querySelector('[data-lab-map-products-action]').onclick = function () {
          setRoute(axis.route, true);
          scrollToArea('productos');
        };
      }

      function selectView(viewKey) {
        root.querySelectorAll('[data-lab-view-trigger]').forEach(function (button) {
          var selected = button.dataset.labViewTrigger === viewKey;
          button.setAttribute('aria-selected', String(selected));
        });
        root.querySelectorAll('[data-lab-view]').forEach(function (panel) {
          panel.hidden = panel.dataset.labView !== viewKey;
        });
        syncBottomNav();
        try { window.localStorage.setItem('alicynLabCollection', viewKey); } catch (error) {}
      }

      function syncBottomNav() {
        var mobile = window.matchMedia && window.matchMedia('(max-width: 749px)').matches;
        var peptides = !root.querySelector('[data-lab-view="peptides"]').hidden;
        var labVisible = Boolean(peptides && appInView);
        var visible = Boolean(bottomNav && mobile && labVisible);
        if (bottomNav) bottomNav.classList.toggle('is-visible', visible);
        if (traditionalSticky) {
          traditionalSticky.hidden = visible;
          traditionalSticky.style.display = visible ? 'none' : '';
        }
        if (traditionalChat) traditionalChat.style.display = labVisible ? 'none' : '';
      }

      function showQuizStep(step) {
        quizStep = Math.max(0, Math.min(step, quizFields.length - 1));
        quizFields.forEach(function (field, index) { field.hidden = index !== quizStep; });
        root.querySelector('[data-lab-quiz-step-label]').textContent = 'Pregunta ' + (quizStep + 1) + ' de ' + quizFields.length;
        root.querySelector('[data-lab-progress]').style.width = ((quizStep + 1) / quizFields.length * 100) + '%';
        root.querySelector('[data-lab-quiz-back]').disabled = quizStep === 0;
        root.querySelector('[data-lab-quiz-next]').textContent = quizStep === quizFields.length - 1 ? 'Ver resultado' : 'Siguiente';
      }

      function readAnswer(name) {
        var selection = root.querySelector('input[name="' + name + '"]:checked');
        return selection ? selection.value : '';
      }

      function quizResult() {
        var selectedRoute = readAnswer('objective') || 'starter';
        var experience = readAnswer('experience');
        var note = root.querySelector('[data-lab-experience-note]');
        setRoute(selectedRoute, true);
        if (experience === 'beginner') {
          note.hidden = false;
          note.textContent = 'Puedes empezar comparando opciones sin comprometerte a una ruta avanzada.';
        } else if (experience === 'advanced') {
          note.hidden = false;
          note.textContent = 'Consulta también los paquetes técnicos del mismo eje para una comparación más amplia.';
        } else {
          note.hidden = true;
        }
        scrollToArea('objetivos');
      }

      root.querySelectorAll('[data-lab-view-trigger]').forEach(function (button) {
        button.addEventListener('click', function () { selectView(button.dataset.labViewTrigger); });
      });

      root.querySelector('[data-lab-menu-toggle]').addEventListener('click', function (event) {
        var menu = root.querySelector('[data-lab-quick-menu]');
        var open = event.currentTarget.getAttribute('aria-expanded') === 'true';
        event.currentTarget.setAttribute('aria-expanded', String(!open));
        menu.hidden = open;
      });

      root.querySelectorAll('[data-lab-scroll-link]').forEach(function (link) {
        link.addEventListener('click', function () {
          root.querySelector('[data-lab-quick-menu]').hidden = true;
          root.querySelector('[data-lab-menu-toggle]').setAttribute('aria-expanded', 'false');
        });
      });

      root.querySelectorAll('[data-lab-go]').forEach(function (button) {
        button.addEventListener('click', function () { scrollToArea(button.dataset.labGo); });
      });

      root.querySelectorAll('[data-lab-route]').forEach(function (button) {
        button.addEventListener('click', function () {
          setRoute(button.dataset.labRoute, true);
          if (button.closest('[data-lab-route-card]')) scrollToArea('objetivos');
        });
      });

      root.querySelectorAll('[data-axis]').forEach(function (button) {
        button.addEventListener('click', function () { setAxis(button.dataset.axis); setRoute(button.dataset.route, false); });
      });

      root.querySelectorAll('[data-lab-filter]').forEach(function (button) {
        button.addEventListener('click', function () { applyFilter(button.dataset.labFilter); });
      });

      root.querySelector('[data-lab-reset-route]').addEventListener('click', function () {
        applyFilter('all');
        root.querySelectorAll('.alicyn-lab-objective-card').forEach(function (card) { card.classList.remove('is-active'); });
      });

      if (root.querySelector('[data-lab-quiz]')) {
        root.querySelector('[data-lab-quiz-next]').addEventListener('click', function () {
          var current = quizFields[quizStep];
          var chosen = current.querySelector('input:checked');
          if (!chosen) {
            current.querySelector('.alicyn-lab-choice').focus();
            return;
          }
          if (quizStep < quizFields.length - 1) showQuizStep(quizStep + 1);
          else quizResult();
        });
        root.querySelector('[data-lab-quiz-back]').addEventListener('click', function () { showQuizStep(quizStep - 1); });
        root.querySelector('[data-lab-clear-quiz]').addEventListener('click', function () {
          root.querySelector('[data-lab-quiz]').reset();
          showQuizStep(0);
        });
        showQuizStep(0);
      }

      root.querySelectorAll('[data-alicyn-lab-faq-button]').forEach(function (button) {
        button.addEventListener('click', function () {
          var answer = root.querySelector('#' + button.getAttribute('aria-controls'));
          var open = button.getAttribute('aria-expanded') === 'true';
          if (!answer) return;
          button.setAttribute('aria-expanded', String(!open));
          button.querySelector('span:last-child').textContent = open ? '+' : '-';
          answer.hidden = open;
        });
      });

      root.querySelectorAll('[data-lab-nav]').forEach(function (button) {
        button.addEventListener('click', function () { scrollToArea(button.dataset.labNav); });
      });

      if ('IntersectionObserver' in window) {
        var appObserver = new IntersectionObserver(function (entries) {
          appInView = entries.some(function (entry) { return entry.isIntersecting; });
          syncBottomNav();
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.02 });
        appObserver.observe(root);

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var key = entry.target.dataset.labNavSection;
            root.querySelectorAll('[data-lab-nav]').forEach(function (button) {
              button.classList.toggle('is-active', button.dataset.labNav === key);
            });
          });
        }, { rootMargin: '-20% 0px -65% 0px', threshold: 0.05 });
        root.querySelectorAll('[data-lab-nav-section]').forEach(function (section) { observer.observe(section); });
      } else {
        appInView = true;
        syncBottomNav();
      }
      window.addEventListener('resize', syncBottomNav);

      var savedView = 'peptides';
      try { savedView = window.localStorage.getItem('alicynLabCollection') || 'peptides'; } catch (error) {}
      selectView(savedView === 'care' ? 'care' : 'peptides');
      setAxis('energy');
      setRoute('cell', false);
      updateWhatsApp('cell');
    })();
  </script>
</section>

