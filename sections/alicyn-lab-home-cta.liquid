<section
  id="AlicynLabHomeCta-{{ section.id }}"
  class="alicyn-lab-home-root"
  style="--alicyn-lab-home-accent: {{ section.settings.accent_color }};"
>
  <style>
    #AlicynLabHomeCta-{{ section.id }} {
      --alicyn-lab-home-text: #e8e8ea;
      --alicyn-lab-home-muted: #a8adb6;
      --alicyn-lab-home-border: rgba(143, 191, 195, 0.2);
      background: #0b0b0d;
      color: var(--alicyn-lab-home-text);
      padding: clamp(36px, 7vw, 68px) 20px;
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-panel {
      background: linear-gradient(130deg, rgba(143, 191, 195, 0.09), rgba(122, 143, 176, 0.04) 48%, rgba(16, 16, 19, 0.95));
      border: 1px solid var(--alicyn-lab-home-border);
      border-radius: 8px;
      display: grid;
      gap: 22px;
      margin: 0 auto;
      max-width: 1160px;
      padding: clamp(28px, 5vw, 48px);
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-brand {
      color: var(--alicyn-lab-home-accent);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      margin: 0 0 12px;
      text-transform: uppercase;
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-title {
      color: var(--alicyn-lab-home-text);
      font-size: clamp(1.55rem, 4vw, 2.35rem);
      font-weight: 500;
      line-height: 1.15;
      margin: 0 0 10px;
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-copy {
      color: var(--alicyn-lab-home-muted);
      line-height: 1.65;
      margin: 0;
      max-width: 650px;
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-button {
      align-items: center;
      background: var(--alicyn-lab-home-accent);
      border-radius: 6px;
      color: #081114;
      display: inline-flex;
      font-weight: 700;
      justify-content: center;
      min-height: 50px;
      padding: 13px 22px;
      text-decoration: none;
      transition: transform 180ms ease, box-shadow 180ms ease;
      width: 100%;
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-button:hover {
      box-shadow: 0 12px 30px rgba(143, 191, 195, 0.18);
      transform: translateY(-1px);
    }

    #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-button:focus-visible {
      outline: 2px solid #e8e8ea;
      outline-offset: 3px;
    }

    @media (min-width: 750px) {
      #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-panel {
        align-items: center;
        grid-template-columns: minmax(0, 1fr) auto;
      }

      #AlicynLabHomeCta-{{ section.id }} .alicyn-lab-home-button {
        width: auto;
      }
    }
  </style>

  <div class="alicyn-lab-home-panel">
    <div>
      <p class="alicyn-lab-home-brand">ALICYN LAB</p>
      <h2 class="alicyn-lab-home-title">{{ section.settings.heading | escape }}</h2>
      <p class="alicyn-lab-home-copy">{{ section.settings.text | escape }}</p>
    </div>
    <a class="alicyn-lab-home-button" href="{{ section.settings.button_link | default: '/collections/peptidos' }}">
      {{ section.settings.button_label | escape }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Alicyn Lab CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Explora Alicyn Lab"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Péptidos Aesthetic Labs para investigación en skin wellness, señalización celular y bienestar avanzado. Uso exclusivo para investigación y laboratorio."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Explorar péptidos"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Enlace del botón",
      "default": "/collections/peptidos"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#8FBFC3"
    }
  ],
  "presets": [
    {
      "name": "Alicyn Lab CTA"
    }
  ]
}
{% endschema %}
