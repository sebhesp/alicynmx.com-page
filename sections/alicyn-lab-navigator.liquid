{{ 'alicyn-lab.css' | asset_url | stylesheet_tag }}
{{ 'alicyn-lab-codeonly.css' | asset_url | stylesheet_tag }}
<script src="{{ 'alicyn-lab.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign p_nad = section.settings.product_nad
  assign p_motsc = section.settings.product_motsc
  assign p_aod = section.settings.product_aod
  assign p_bpc157 = section.settings.product_bpc157
  assign p_tb500 = section.settings.product_tb500
  assign p_ghkcu = section.settings.product_ghkcu
  assign p_cjc1295 = section.settings.product_cjc1295
  assign p_ipamorelin = section.settings.product_ipamorelin
  assign antiseptic_product = section.settings.antiseptic_product
  assign antiseptic_url = section.settings.antiseptic_link
  if antiseptic_product != blank
    assign antiseptic_url = antiseptic_product.url
  endif
%}

<section
  class="aln"
  id="AlicynLabNavigator-{{ section.id }}"
  data-aln
  data-section-id="{{ section.id }}"
  data-default-view="{{ section.settings.default_view }}"
  style="--aln-accent: {{ section.settings.accent_color }}; --aln-accent-2: {{ section.settings.accent_secondary }}; --aln-bg: {{ section.settings.background_color }};"
>
  <header class="aln-header" id="aln-inicio-{{ section.id }}">
    <div class="aln-shell aln-appbar">
      <button class="aln-menu" type="button" aria-label="Ir a objetivos" data-aln-scroll="objectives"><span></span><span></span><span></span></button>
      <a href="{{ routes.root_url }}" class="aln-wordmark" aria-label="Alicyn Lab">
        <strong>ALICYN <span>LAB</span></strong>
        <small>CIENCIA <i></i> BIENESTAR <i></i> EVOLUCIÓN</small>
      </a>
      <a class="aln-bag" href="{{ routes.cart_url }}" aria-label="Ver carrito">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 8h12l1 13H5L6 8Zm3 0V6a3 3 0 0 1 6 0v2"/></svg>
      </a>
    </div>
    <div class="aln-shell">
      <div class="aln-mode-switch" role="tablist" aria-label="Seleccionar experiencia Alicyn">
        <button type="button" role="tab" data-aln-view-button="antiseptic" aria-controls="aln-antiseptic-{{ section.id }}">Antiséptico</button>
        <button type="button" role="tab" data-aln-view-button="peptides" aria-controls="aln-peptides-{{ section.id }}">Péptidos</button>
        <span aria-hidden="true"></span>
      </div>
    </div>
  </header>

  <div id="aln-antiseptic-{{ section.id }}" class="aln-view aln-antiseptic" data-aln-view="antiseptic" role="tabpanel">
    <div class="aln-shell aln-antiseptic-grid">
      <div class="aln-antiseptic-visual">
        <div class="aln-bottle" aria-hidden="true"><span>ALICYN</span></div>
      </div>
      <div class="aln-antiseptic-copy">
        <p class="aln-eyebrow">Alicyn · Cuidado especializado</p>
        <h2>{{ section.settings.antiseptic_heading | escape }}</h2>
        <p>{{ section.settings.antiseptic_copy | escape }}</p>
        <ul class="aln-checklist">
          <li>Cuidado postprocedimiento.</li>
          <li>Limpieza profunda y cuidadosa.</li>
          <li>Alivio de molestias comunes.</li>
          <li>Uso antes y después de procedimientos.</li>
        </ul>
        <div class="aln-actions">
          <a class="aln-btn aln-btn-primary" href="{{ antiseptic_url | default: '/collections/all' }}">Comprar Alicyn</a>
          <a class="aln-btn aln-btn-secondary" href="{{ section.settings.antiseptic_care_link }}">Ver cuidados por zona</a>
        </div>
      </div>
    </div>
  </div>

  <div id="aln-peptides-{{ section.id }}" class="aln-view" data-aln-view="peptides" role="tabpanel">
    <div class="aln-shell">
      <section class="aln-hero" aria-labelledby="aln-title-{{ section.id }}">
        <div class="aln-hero-grid">
          <div class="aln-hero-copyblock">
            <h1 id="aln-title-{{ section.id }}"><span>{{ section.settings.lab_heading_intro | escape }}</span><em>{{ section.settings.lab_heading_focus | escape }}</em></h1>
            <p class="aln-hero-copy">{{ section.settings.lab_copy | escape }}</p>
            <div class="aln-actions">
              <button class="aln-btn aln-btn-primary" type="button" data-aln-scroll="quiz">Encontrar mi péptido <span>→</span></button>
              <button class="aln-btn aln-btn-secondary" type="button" data-aln-scroll="objectives">Explorar por objetivo <span>→</span></button>
            </div>
          </div>
          <div class="aln-axis-menu" aria-label="Menú interactivo de ejes Alicyn Lab">
            <div class="aln-axis-tabs" role="list" aria-label="Selecciona un eje de investigación">
              <button class="aln-axis-tab" type="button" data-aln-axis="energy"><span>{% render 'alicyn-lab-icon', name: 'dna' %}</span><strong>Longevidad</strong><small>NAD+ · MOTS-C</small></button>
              <button class="aln-axis-tab" type="button" data-aln-axis="skin"><span>{% render 'alicyn-lab-icon', name: 'skin' %}</span><strong>Skin science</strong><small>GHK-Cu · NAD+</small></button>
              <button class="aln-axis-tab" type="button" data-aln-axis="metabolism"><span>{% render 'alicyn-lab-icon', name: 'body' %}</span><strong>Metabolismo</strong><small>AOD · MOTS-C</small></button>
              <button class="aln-axis-tab" type="button" data-aln-axis="recovery"><span>{% render 'alicyn-lab-icon', name: 'joint' %}</span><strong>Recuperación</strong><small>BPC · TB-500</small></button>
              <button class="aln-axis-tab" type="button" data-aln-axis="performance"><span>{% render 'alicyn-lab-icon', name: 'bolt' %}</span><strong>Performance</strong><small>MOTS-C · CJC</small></button>
            </div>

            <div class="aln-axis-explorer">
              <div class="aln-body-map" id="aln-map-{{ section.id }}" aria-label="Selecciona una zona de interés">
                <div class="aln-code-map" aria-hidden="true">
                  <span class="aln-orbit aln-orbit-one"></span>
                  <span class="aln-orbit aln-orbit-two"></span>
                  <span class="aln-scanline"></span>
                  <svg viewBox="0 0 320 320" class="aln-network" aria-hidden="true">
                    <defs>
                      <linearGradient id="aln-network-gradient-{{ section.id }}" x1="40" y1="34" x2="286" y2="290" gradientUnits="userSpaceOnUse">
                        <stop offset="0" stop-color="{{ section.settings.accent_secondary }}" stop-opacity=".75"/>
                        <stop offset=".52" stop-color="{{ section.settings.accent_color }}" stop-opacity=".95"/>
                        <stop offset="1" stop-color="#ffffff" stop-opacity=".4"/>
                      </linearGradient>
                    </defs>
                    <path d="M160 43 C221 62 262 113 257 174 C251 239 205 281 160 285 C115 281 69 239 63 174 C58 113 99 62 160 43Z"/>
                    <path d="M160 76 C195 94 216 126 216 162 C216 200 195 231 160 248 C125 231 104 200 104 162 C104 126 125 94 160 76Z"/>
                    <path class="aln-network-line" d="M160 62V260M86 138H234M98 214H222M78 104L160 160 242 104M88 248L160 160 232 248"/>
                    <circle cx="160" cy="160" r="34"/>
                  </svg>
                  <div class="aln-map-core">
                    <b>ALICYN</b>
                    <small>LAB</small>
                  </div>
                </div>
                <button type="button" class="aln-node aln-node-energy" data-aln-map="energy"><span class="aln-node-icon">{% render 'alicyn-lab-icon', name: 'dna' %}</span><strong>Energía celular</strong><small>NAD+ · MOTS-C</small></button>
                <button type="button" class="aln-node aln-node-skin" data-aln-map="skin"><span class="aln-node-icon">{% render 'alicyn-lab-icon', name: 'skin' %}</span><strong>Piel / Rostro</strong><small>GHK-Cu · NAD+</small></button>
                <button type="button" class="aln-node aln-node-metabolism" data-aln-map="metabolism"><span class="aln-node-icon">{% render 'alicyn-lab-icon', name: 'body' %}</span><strong>Metabolismo</strong><small>AOD · MOTS-C</small></button>
                <button type="button" class="aln-node aln-node-tissue" data-aln-map="recovery"><span class="aln-node-icon">{% render 'alicyn-lab-icon', name: 'joint' %}</span><strong>Tejidos</strong><small>BPC · TB-500</small></button>
                <button type="button" class="aln-node aln-node-performance" data-aln-map="performance"><span class="aln-node-icon">{% render 'alicyn-lab-icon', name: 'bolt' %}</span><strong>Performance</strong><small>MOTS-C · CJC</small></button>
              </div>

              <aside class="aln-map-result aln-axis-card is-open" data-aln-map-result aria-live="polite">
                <div class="aln-axis-card-head">
                  <p class="aln-eyebrow">Eje seleccionado</p>
                  <span data-aln-map-route>Cell Reset</span>
                </div>
                <h3>Energía celular</h3>
                <p class="aln-map-description">Explora opciones organizadas por interés técnico.</p>
                <div class="aln-mini-block">
                  <span>Funciones</span>
                  <div class="aln-mini-chips" data-aln-map-functions></div>
                </div>
                <div class="aln-mini-block">
                  <span>Productos</span>
                  <div class="aln-product-pills" data-aln-map-product-buttons></div>
                </div>
                <p class="aln-map-products" hidden></p>
                <div class="aln-actions aln-actions-compact">
                  <button class="aln-btn aln-btn-primary" type="button" data-aln-map-route-button>Ver ruta</button>
                  <button class="aln-btn aln-btn-secondary" type="button" data-aln-map-compare>Comparar</button>
                  <button class="aln-link" type="button" data-aln-scroll="quiz">Hacer quiz</button>
                  <button class="aln-link" type="button" data-aln-show-products>Ver todos</button>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>

      <section class="aln-dashboard aln-panel" id="aln-dashboard-{{ section.id }}">
      <section class="aln-objectives" id="aln-objectives-{{ section.id }}" data-aln-anchor="objectives" aria-labelledby="aln-objectives-title-{{ section.id }}">
        <div class="aln-section-head"><h2 id="aln-objectives-title-{{ section.id }}">Elige tu objetivo principal</h2><button class="aln-link" type="button" data-aln-show-products>Ver todos</button></div>
        <div class="aln-objective-track">
          <button class="aln-objective" type="button" data-aln-objective="energy"><span class="aln-icon">{% render 'alicyn-lab-icon', name: 'dna' %}</span><strong>Longevidad celular</strong><small>Energía, metabolismo y longevidad experimental</small></button>
          <button class="aln-objective" type="button" data-aln-objective="metabolism"><span class="aln-icon">{% render 'alicyn-lab-icon', name: 'body' %}</span><strong>Composición corporal</strong><small>Metabolismo celular experimental</small></button>
          <button class="aln-objective" type="button" data-aln-objective="recovery"><span class="aln-icon">{% render 'alicyn-lab-icon', name: 'joint' %}</span><strong>Recuperación</strong><small>Tejidos y señalización celular</small></button>
          <button class="aln-objective" type="button" data-aln-objective="skin"><span class="aln-icon">{% render 'alicyn-lab-icon', name: 'skin' %}</span><strong>Skin science</strong><small>Piel, colágeno y bienestar estético</small></button>
          <button class="aln-objective" type="button" data-aln-objective="performance"><span class="aln-icon">{% render 'alicyn-lab-icon', name: 'bolt' %}</span><strong>Performance</strong><small>Energía y señalización avanzada</small></button>
        </div>
      </section>

      <article class="aln-quiz-promo">
        <div>
          <h3>¿No sabes cuál elegir?</h3>
          <p>Responde 4 preguntas y te guiamos hacia el eje de investigación más compatible con tu objetivo.</p>
          <button class="aln-btn aln-btn-primary" type="button" data-aln-scroll="quiz">Comenzar quiz <span>→</span></button>
        </div>
        <div class="aln-promo-vials" aria-hidden="true">
          <span></span><span></span><span></span>
          <b>INVESTIGACIÓN<br>AVANZADA</b>
        </div>
      </article>

      <section class="aln-routes" aria-labelledby="aln-routes-title-{{ section.id }}">
        <div class="aln-section-head"><h2 id="aln-routes-title-{{ section.id }}">Rutas recomendadas</h2><button class="aln-link" type="button" data-aln-scroll="products">Ver todas</button></div>
        <div class="aln-route-track">
          <article class="aln-route" data-route="energy"><h3>Cell Reset</h3><strong>NAD+ + MOTS-C</strong><small>Energía celular y metabolismo</small><div class="aln-route-actions"><button type="button" class="aln-card-link" data-aln-route-view="energy">Ver ruta →</button><a class="aln-card-link" data-aln-route-direct="energy">WhatsApp</a></div></article>
          <article class="aln-route" data-route="metabolism"><h3>Lean Research</h3><strong>AOD-9604 + MOTS-C</strong><small>Metabolismo celular experimental</small><div class="aln-route-actions"><button type="button" class="aln-card-link" data-aln-route-view="metabolism">Ver ruta →</button><a class="aln-card-link" data-aln-route-direct="metabolism">WhatsApp</a></div></article>
          <article class="aln-route" data-route="recovery"><h3>Recovery Lab</h3><strong>BPC-157 + TB-500</strong><small>Respuesta tisular experimental</small><div class="aln-route-actions"><button type="button" class="aln-card-link" data-aln-route-view="recovery">Ver ruta →</button><a class="aln-card-link" data-aln-route-direct="recovery">WhatsApp</a></div></article>
          <article class="aln-route" data-route="skin"><h3>Skin Matrix</h3><strong>GHK-Cu + NAD+</strong><small>Skin science experimental</small><div class="aln-route-actions"><button type="button" class="aln-card-link" data-aln-route-view="skin">Ver ruta →</button><a class="aln-card-link" data-aln-route-direct="skin">WhatsApp</a></div></article>
          <article class="aln-route" data-route="performance"><h3>Performance Axis</h3><strong>MOTS-C + CJC-1295</strong><small>Señalización avanzada</small><div class="aln-route-actions"><button type="button" class="aln-card-link" data-aln-route-view="performance">Ver ruta →</button><a class="aln-card-link" data-aln-route-direct="performance">WhatsApp</a></div></article>
        </div>
      </section>
      </section>

      <section class="aln-recommendation aln-panel" data-aln-recommendation hidden aria-live="polite">
        <div class="aln-route-pill">Ruta recomendada <strong data-aln-route-name></strong></div>
        <div class="aln-result-grid">
          <div><p class="aln-caption">Producto principal</p><h3 data-aln-primary></h3></div>
          <div><p class="aln-caption">Complemento opcional</p><h3 data-aln-complement></h3></div>
        </div>
        <p data-aln-result-description></p>
        <p class="aln-disclaimer-inline">Ruta educativa para productos de investigación; no representa indicación sanitaria.</p>
        <div class="aln-actions">
          <a class="aln-btn aln-btn-primary" data-aln-primary-link>Ver producto</a>
          <button class="aln-btn aln-btn-secondary" type="button" data-aln-result-compare>Comparar</button>
          <button class="aln-link" type="button" data-aln-scroll="objectives">Cambiar objetivo</button>
          <a class="aln-btn aln-btn-whatsapp" target="_blank" rel="noopener noreferrer" data-aln-route-whatsapp>WhatsApp</a>
        </div>
      </section>

      <section class="aln-quiz aln-panel" id="aln-quiz-{{ section.id }}" data-aln-anchor="quiz" aria-labelledby="aln-quiz-title-{{ section.id }}">
        <div class="aln-section-head"><div><p class="aln-eyebrow">Guía personalizada</p><h2 id="aln-quiz-title-{{ section.id }}">Encuentra tu ruta</h2></div><span class="aln-progress-label" data-aln-progress>1 / 4</span></div>
        <div class="aln-progress"><span data-aln-progress-bar></span></div>
        <form data-aln-quiz>
          <fieldset class="aln-question" data-aln-question="0"><legend>¿Cuál es tu objetivo principal?</legend><div class="aln-options">
            <button type="button" data-answer="energy">Energía y longevidad</button><button type="button" data-answer="metabolism">Composición corporal</button><button type="button" data-answer="recovery">Recuperación</button><button type="button" data-answer="skin">Piel y estética</button><button type="button" data-answer="performance">Performance</button><button type="button" data-answer="starter">No estoy seguro</button>
          </div></fieldset>
          <fieldset class="aln-question" data-aln-question="1" hidden><legend>¿Qué nivel de experiencia tienes con péptidos?</legend><div class="aln-options"><button type="button" data-answer="starter">Estoy empezando</button><button type="button" data-answer="familiar">Ya conozco algunos</button><button type="button" data-answer="advanced">Busco una ruta avanzada</button></div></fieldset>
          <fieldset class="aln-question" data-aln-question="2" hidden><legend>¿Qué prefieres explorar?</legend><div class="aln-options"><button type="button" data-answer="single">Un producto individual</button><button type="button" data-answer="pair">Una combinación sencilla</button><button type="button" data-answer="complete">Una ruta completa</button><button type="button" data-answer="learn">Primero entender opciones</button></div></fieldset>
          <fieldset class="aln-question" data-aln-question="3" hidden><legend>¿Qué tipo de guía necesitas?</legend><div class="aln-options"><button type="button" data-answer="simple">Algo simple y directo</button><button type="button" data-answer="compare">Comparar opciones</button><button type="button" data-answer="whatsapp">Hablar por WhatsApp</button><button type="button" data-answer="details">Ver información completa</button></div></fieldset>
          <div class="aln-quiz-nav"><button class="aln-link" type="button" data-aln-back disabled>Regresar</button><button class="aln-btn aln-btn-primary" type="button" data-aln-finish hidden>Ver resultado</button></div>
        </form>
        <div class="aln-quiz-result" data-aln-quiz-result hidden>
          <p class="aln-eyebrow">Tu resultado</p><h3 data-aln-quiz-route></h3>
          <div class="aln-result-grid"><div><p class="aln-caption">Producto principal</p><strong data-aln-quiz-primary></strong></div><div><p class="aln-caption">Complemento opcional</p><strong data-aln-quiz-complement></strong></div><div><p class="aln-caption">Nivel sugerido</p><strong data-aln-quiz-level></strong></div></div>
          <p data-aln-quiz-description></p>
          <p class="aln-disclaimer-inline">Tu recomendación no es definitiva: puedes explorar otras opciones. Productos para investigación y laboratorio.</p>
          <div class="aln-actions"><a class="aln-btn aln-btn-primary" data-aln-quiz-product>Ver producto</a><button class="aln-btn aln-btn-secondary" type="button" data-aln-quiz-compare>Comparar</button><button class="aln-link" type="button" data-aln-scroll="objectives">Cambiar objetivo</button><button class="aln-link" type="button" data-aln-restart>Volver al quiz</button><a class="aln-btn aln-btn-whatsapp" target="_blank" rel="noopener noreferrer" data-aln-quiz-whatsapp>WhatsApp</a></div>
        </div>
      </section>

      <section class="aln-compare aln-panel" id="aln-compare-{{ section.id }}" data-aln-anchor="compare" aria-labelledby="aln-compare-title-{{ section.id }}">
        <div class="aln-section-head"><div><p class="aln-eyebrow">Comparador</p><h2 id="aln-compare-title-{{ section.id }}">Compara antes de elegir</h2></div><button class="aln-link" type="button" data-aln-show-products>Ver todos los productos</button></div>
        <div class="aln-compare-scroll"><table><thead><tr><th>Péptido</th><th>Eje principal</th><th>Ideal para investigación de</th><th>Nivel</th><th>Ruta</th><th></th></tr></thead><tbody>
          <tr data-aln-compare-row="nad"><th>NAD+ 1000 mg</th><td>Longevidad celular</td><td>Energía celular y wellness avanzado</td><td>Inicial / intermedio</td><td>Cell Reset</td><td><button data-aln-focus-product="nad">Ver</button></td></tr>
          <tr data-aln-compare-row="motsc"><th>MOTS-C 10 mg</th><td>Metabolismo / performance</td><td>Energía y metabolismo celular</td><td>Intermedio</td><td>Cell Reset / Lean Research</td><td><button data-aln-focus-product="motsc">Ver</button></td></tr>
          <tr data-aln-compare-row="aod"><th>AOD-9604 10 mg</th><td>Composición corporal</td><td>Metabolismo experimental</td><td>Inicial / intermedio</td><td>Lean Research</td><td><button data-aln-focus-product="aod">Ver</button></td></tr>
          <tr data-aln-compare-row="bpc157"><th>BPC-157</th><td>Respuesta tisular</td><td>Señalización y tejidos</td><td>Intermedio</td><td>Recovery Lab</td><td><button data-aln-focus-product="bpc157">Ver</button></td></tr>
          <tr data-aln-compare-row="tb500"><th>TB-500</th><td>Respuesta tisular avanzada</td><td>Modelos experimentales de movilidad</td><td>Intermedio / avanzado</td><td>Recovery Lab</td><td><button data-aln-focus-product="tb500">Ver</button></td></tr>
          <tr data-aln-compare-row="ghkcu"><th>GHK-Cu 100 mg</th><td>Skin science</td><td>Piel y bienestar estético</td><td>Inicial / intermedio</td><td>Skin Matrix</td><td><button data-aln-focus-product="ghkcu">Ver</button></td></tr>
          <tr data-aln-compare-row="cjc1295"><th>CJC-1295 sin DAC</th><td>Señalización avanzada</td><td>Ejes experimentales avanzados</td><td>Avanzado</td><td>Performance Axis</td><td><button data-aln-focus-product="cjc1295">Ver</button></td></tr>
          <tr data-aln-compare-row="ipamorelin"><th>Ipamorelin</th><td>Señalización avanzada</td><td>Protocolos técnicos avanzados</td><td>Avanzado</td><td>Performance Axis</td><td><button data-aln-focus-product="ipamorelin">Ver</button></td></tr>
        </tbody></table></div>
      </section>

      <section class="aln-products" id="aln-products-{{ section.id }}" data-aln-anchor="products" aria-labelledby="aln-products-title-{{ section.id }}">
        <div class="aln-section-head"><div><p class="aln-eyebrow">Aesthetic Labs</p><h2 id="aln-products-title-{{ section.id }}">Productos de investigación</h2></div><p>Selecciona, compara o consulta disponibilidad.</p></div>
        <div class="aln-product-grid">
          {% render 'alicyn-lab-product-card', product: p_nad, key: 'nad', fallback_title: 'Aesthetic Labs NAD+ 1000 mg', fallback_price: '$2,000 MXN', axis: 'Longevidad celular', description: 'Energía celular y bienestar avanzado en investigación.', level: 'Inicial / intermedio', route_key: 'energy', section_id: section.id %}
          {% render 'alicyn-lab-product-card', product: p_motsc, key: 'motsc', fallback_title: 'Aesthetic Labs MOTS-C 10 mg', fallback_price: '$1,800 MXN', axis: 'Metabolismo celular', description: 'Investigación mitocondrial y energía celular.', level: 'Intermedio', route_key: 'energy', section_id: section.id %}
          {% render 'alicyn-lab-product-card', product: p_aod, key: 'aod', fallback_title: 'Aesthetic Labs AOD-9604 10 mg', fallback_price: '$1,600 MXN', axis: 'Metabolismo experimental', description: 'Análisis técnico en composición corporal experimental.', level: 'Inicial / intermedio', route_key: 'metabolism', section_id: section.id %}
