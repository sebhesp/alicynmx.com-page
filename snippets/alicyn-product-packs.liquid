{% liquid
  assign single_handle = product_single_handle | default: 'alicyn-solucion-antiseptica'
  assign pack_2_handle = product_pack_2_handle | default: 'alicyn-pack-2'
  assign pack_3_handle = product_pack_3_handle | default: 'alicyn-pack-3'
  assign pack_4_handle = product_pack_4_handle | default: 'alicyn-pack-4'
  assign pack_5_handle = product_pack_5_handle | default: 'alicyn-pack-5'
  assign packs_eyebrow_text = packs_eyebrow | default: 'Compra directa'
  assign packs_heading_text = packs_heading | default: 'Compra individual o en grupo'
  assign packs_copy_text = packs_copy | default: 'Pide una pieza para tu cuidado personal o arma un pedido con amigos para aprovechar mejor el envío y mejorar el precio por pieza.'
  assign whatsapp_fallback_url = whatsapp_url | default: 'https://wa.me/525542388056?text=Hola%2C%20quiero%20comprar%20Alicyn'
  assign product_url_value = product_url | default: '/products/alicyn-solucion-antiseptica'
  assign checkout_url_value = checkout_url | default: ''

  assign single_product = all_products[single_handle]
  assign pack_2_product = all_products[pack_2_handle]
  assign pack_3_product = all_products[pack_3_handle]
  assign pack_4_product = all_products[pack_4_handle]
  assign pack_5_product = all_products[pack_5_handle]

  assign pack_visual_enabled = true
  if show_pack_images == false
    assign pack_visual_enabled = false
  endif
  assign pack_visual_image = pack_product_image
  if pack_visual_image == blank
    assign pack_visual_image = fallback_product_image
  endif
  assign pack_visual_alt = pack_product_image_alt | default: 'Alicyn solución antiséptica 100 ml para cuidado post-piercing'
  assign pack_visual_style = pack_image_style | default: 'stacked'
  assign pack_visual_scale = pack_image_scale | default: 100 | divided_by: 100.0
%}

<section id="packs" class="alicyn-packs section-pad" aria-labelledby="alicyn-packs-title">
  <div class="section-heading">
    <p class="eyebrow">{{ packs_eyebrow_text | escape }}</p>
    <h2 id="alicyn-packs-title">{{ packs_heading_text | escape }}</h2>
    <p>{{ packs_copy_text | escape }}</p>
    <p class="alicyn-pack-shipping-note">El envío se cotiza en checkout con Skydrop según tu dirección.</p>
  </div>

  <div class="alicyn-pack-grid" aria-label="Packs disponibles de Alicyn">
    <article class="alicyn-pack-card">
      {% assign pack_count = 1 %}
      {% assign pack_image_count = pack_count %}
      {% if pack_visual_style == 'single' %}
        {% assign pack_image_count = 1 %}
      {% endif %}
      {% if pack_visual_enabled %}
        <div class="alicyn-pack-visual alicyn-pack-visual-{{ pack_visual_style }}" data-pack-count="{{ pack_count }}" style="--pack-image-scale: {{ pack_visual_scale }};">
          <div class="alicyn-pack-image-stack">
            {% for image_index in (1..pack_image_count) %}
              {% capture current_alt %}{% if forloop.first %}Pack 1 de {{ pack_visual_alt }}{% endif %}{% endcapture %}
              {% if pack_visual_image != blank %}
                <img
                  class="alicyn-pack-product-image"
                  src="{{ pack_visual_image | image_url: width: 320 }}"
                  srcset="{{ pack_visual_image | image_url: width: 220 }} 220w, {{ pack_visual_image | image_url: width: 320 }} 320w"
                  sizes="110px"
                  alt="{{ current_alt | strip | escape }}"
                  width="180"
                  height="260"
                  loading="lazy"
                  {% unless forloop.first %}aria-hidden="true"{% endunless %}
                >
              {% else %}
                <img
                  class="alicyn-pack-product-image"
                  src="{{ 'alicyn-product.png' | asset_url }}"
                  alt="{{ current_alt | strip | escape }}"
                  width="180"
                  height="260"
                  loading="lazy"
                  onerror="this.style.display='none';"
                  {% unless forloop.first %}aria-hidden="true"{% endunless %}
                >
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
      <span class="alicyn-pack-kicker">1 pieza</span>
      <h3>Alicyn 100 ml</h3>
      {% if single_product != blank and single_product.available and single_product.selected_or_first_available_variant != blank %}
        <strong class="alicyn-pack-price">{{ single_product.price | money }}</strong>
        <p class="alicyn-pack-unit">{{ single_product.price | money }} por pieza</p>
      {% else %}
        <strong class="alicyn-pack-price">Precio objetivo: $350 MXN</strong>
        <p class="alicyn-pack-unit">$350 MXN por pieza</p>
      {% endif %}
      <p>Para cuidado personal.</p>
      {% render 'alicyn-buy-actions',
        product_handle: single_handle,
        quantity: 1,
        primary_label: 'Agregar al carrito',
        secondary_label: 'Comprar ahora',
        fallback_url: product_url_value,
        whatsapp_url: whatsapp_fallback_url,
        checkout_url: checkout_url_value,
        show_add_to_cart: true,
        show_buy_now: true,
        setup_message: 'Configura este producto en Shopify Admin para activar compra directa.'
      %}
    </article>

