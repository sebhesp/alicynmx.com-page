{% liquid
  assign display_title = fallback_title
  assign display_url = ''
  assign display_price = fallback_price
  assign available_variant = blank
  if product != blank
    assign display_title = product.title
    assign display_url = product.url
    assign display_price = product.price | money
    if product.available and product.selected_or_first_available_variant.available
      assign available_variant = product.selected_or_first_available_variant
    endif
  endif
%}
<article class="aln-product-card" id="aln-product-{{ key }}-{{ section_id }}" data-aln-product-card="{{ key }}" data-aln-route="{{ route_key }}">
  <div class="aln-product-media aln-product-media-codeonly">
    <span class="aln-vial" aria-hidden="true"><span></span>{% render 'alicyn-lab-icon', name: 'vial' %}</span>
    <span class="aln-product-badge">{{ level | escape }}</span>
  </div>
  <div class="aln-product-body">
    <p class="aln-product-axis">{{ axis | escape }}</p>
    <h3>{{ display_title | escape }}</h3>
    <p>{{ description | escape }}</p>
    <div class="aln-product-price">{{ display_price | escape }}</div>
    <div class="aln-card-actions">
      {% if display_url != blank %}
        <a class="aln-btn aln-btn-small aln-btn-secondary" href="{{ display_url }}">Ver producto</a>
      {% else %}
        <a class="aln-btn aln-btn-small aln-btn-secondary" href="#aln-contact-{{ section_id }}" data-aln-product-whatsapp="{{ fallback_title | escape }}">Consultar disponibilidad</a>
      {% endif %}
      {% if available_variant != blank %}
        <button class="aln-btn aln-btn-small aln-btn-primary" type="button" data-aln-add="{{ available_variant.id }}" data-product-name="{{ display_title | escape }}">Agregar</button>
      {% endif %}
      <a class="aln-icon-action" href="#aln-contact-{{ section_id }}" data-aln-product-whatsapp="{{ display_title | escape }}" aria-label="Preguntar por {{ display_title | escape }} en WhatsApp">WhatsApp</a>
    </div>
    <p class="aln-lab-only">Uso exclusivo para investigación y laboratorio.</p>
  </div>
</article>
